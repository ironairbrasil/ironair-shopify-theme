{{ 'header.css' | asset_url | stylesheet_tag }}
{{ 'navigation.css' | asset_url | stylesheet_tag }}

{% assign has_logo_block = false %}
{% assign has_search_block = false %}
{% assign has_account_block = false %}
{% assign has_cart_block = false %}

{% for block in section.blocks %}
  {% case block.type %}
    {% when 'logo' %}
      {% assign has_logo_block = true %}
    {% when 'search' %}
      {% assign has_search_block = true %}
    {% when 'account' %}
      {% assign has_account_block = true %}
    {% when 'cart' %}
      {% assign has_cart_block = true %}
  {% endcase %}
{% endfor %}

<div class="header-shell theme-text-align-{{ section.settings.text_alignment | default: 'left' }}{% if section.settings.hide_on_mobile %} theme-hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} theme-hide-desktop{% endif %}" data-ironair-header>
  <header>
    <div class="header-inner">
      <button type="button" class="mobile-menu-toggle" data-mobile-menu-toggle aria-label="Abrir menu" aria-expanded="false">
        {% render 'icon', icon: 'menu' %}
      </button>

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'logo' %}
            <a href="{{ routes.root_url }}" class="logo" {{ block.shopify_attributes }}>
              {% if block.settings.logo != blank %}
                {{ block.settings.logo | image_url: width: 520 | image_tag: alt: shop.name, loading: 'eager' }}
              {% else %}
                <img src="{{ 'logo-1.png' | asset_url }}" alt="{{ shop.name }}" width="180" height="52">
              {% endif %}
            </a>

          {% when 'search' %}
            {% if block.settings.enabled %}
              <form action="{{ routes.search_url }}" method="get" class="header-search" role="search" {{ block.shopify_attributes }}>
                <div class="header-search-bar">
                  <input name="q" type="search" value="{{ search.terms | escape }}" placeholder="{{ block.settings.placeholder }}">
                  <button type="submit" aria-label="{{ block.settings.button_label }}">{% render 'icon', icon: 'search' %}</button>
                </div>
              </form>
            {% endif %}
        {% endcase %}
      {% endfor %}

      {% unless has_logo_block %}
        <a href="{{ routes.root_url }}" class="logo">
          <img src="{{ 'logo-1.png' | asset_url }}" alt="{{ shop.name }}" width="180" height="52">
        </a>
      {% endunless %}

      {% unless has_search_block %}
        <form action="{{ routes.search_url }}" method="get" class="header-search" role="search">
          <div class="header-search-bar">
            <input name="q" type="search" value="{{ search.terms | escape }}" placeholder="Buscar produtos...">
            <button type="submit" aria-label="Buscar">{% render 'icon', icon: 'search' %}</button>
          </div>
        </form>
      {% endunless %}

      <div class="header-icons header-icons-desktop">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'account' %}
              {% if block.settings.enabled %}
                <div {{ block.shopify_attributes }}>
                  {% render 'header-account-menu' %}
                </div>
              {% endif %}

            {% when 'cart' %}
              {% if block.settings.enabled %}
                <button type="button" class="hicon js-cart-drawer-open" aria-controls="CartDrawer" aria-expanded="false" aria-label="Carrinho" {{ block.shopify_attributes }}>
                  {% render 'icon', icon: 'cart' %}
                  <span class="badge" data-cart-count>{{ cart.item_count }}</span>
                </button>
              {% endif %}
          {% endcase %}
        {% endfor %}

        {% unless has_account_block %}
          {% render 'header-account-menu' %}
        {% endunless %}

        {% unless has_cart_block %}
          <button type="button" class="hicon js-cart-drawer-open" aria-controls="CartDrawer" aria-expanded="false" aria-label="Carrinho">
            {% render 'icon', icon: 'cart' %}
            <span class="badge" data-cart-count>{{ cart.item_count }}</span>
          </button>
        {% endunless %}
      </div>

      <div class="mobile-header-actions">
        {% render 'header-account-menu', class: 'mobile-header-action' %}
        <button type="button" class="hicon mobile-header-action mobile-cart-button js-cart-drawer-open" aria-controls="CartDrawer" aria-expanded="false" aria-label="Carrinho">
          {% render 'icon', icon: 'cart' %}
          <span class="mobile-cart-badge" data-cart-count>{{ cart.item_count }}</span>
        </button>
      </div>
    </div>
  </header>

</div>

{% schema %}
{
  "name": "Cabeçalho",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alinhamento dos textos",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "header",
      "content": "Visibilidade"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Ocultar no mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Ocultar no desktop",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        }
      ]
    },
    {
      "type": "search",
      "name": "Busca",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "enabled",
          "label": "Mostrar busca",
          "default": true
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "Placeholder",
          "default": "Buscar produtos..."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Rótulo do botão",
          "default": "Buscar"
        }
      ]
    },
    {
      "type": "account",
      "name": "Conta",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "enabled",
          "label": "Mostrar conta",
          "default": true
        }
      ]
    },
    {
      "type": "cart",
      "name": "Carrinho",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "enabled",
          "label": "Mostrar carrinho",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cabeçalho",
      "blocks": [
        {
          "type": "logo"
        },
        {
          "type": "search"
        },
        {
          "type": "account"
        },
        {
          "type": "cart"
        }
      ]
    }
  ]
}
{% endschema %}
