{{ 'collection-page.css' | asset_url | stylesheet_tag }}
{{ 'featured-products.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{% assign products_by_creation = collection.products | sort: 'created_at' %}

<section class="page page-stack shopify-padding-section theme-text-align-{{ section.settings.text_alignment | default: 'left' }}{% if section.settings.hide_on_mobile %} theme-hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} theme-hide-desktop{% endif %}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% if section.blocks.size > 0 %}
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'title' %}
          <div class="sec-header" {{ block.shopify_attributes }}>
            <div class="sec-header-copy">
              <div class="sec-title responsive-font-size" style="--font-size-desktop: {{ block.settings.title_size | default: 26 }}px; --font-size-mobile: {{ block.settings.title_size_mobile | default: block.settings.title_size | default: 26 }}px;">{{ block.settings.title | escape }}</div>
              {% if block.settings.show_product_count %}
                <span class="sec-subtitle responsive-font-size" style="--font-size-desktop: {{ block.settings.subtitle_size | default: 13 }}px; --font-size-mobile: {{ block.settings.subtitle_size_mobile | default: block.settings.subtitle_size | default: 13 }}px;">{{ collection.products_count }} produto{% unless collection.products_count == 1 %}s{% endunless %}</span>
              {% elsif block.settings.subtitle != blank %}
                <span class="sec-subtitle responsive-font-size" style="--font-size-desktop: {{ block.settings.subtitle_size | default: 13 }}px; --font-size-mobile: {{ block.settings.subtitle_size_mobile | default: block.settings.subtitle_size | default: 13 }}px;">{{ block.settings.subtitle | escape }}</span>
              {% endif %}
            </div>
          </div>

        {% when 'products' %}
          <div class="products-grid cols{{ block.settings.columns_desktop }} is-stack-mobile" {{ block.shopify_attributes }}>
            {% for product in products_by_creation %}
              {% render 'product-card',
                product: product,
                show_media: block.settings.show_media,
                media_ratio: block.settings.media_ratio,
                border_style: block.settings.border_style,
                corner_radius: block.settings.corner_radius
              %}
            {% else %}
              <div class="content-card collection-empty">
                <p>Nenhum produto encontrado nesta coleção.</p>
              </div>
            {% endfor %}
          </div>
      {% endcase %}
    {% endfor %}
  {% else %}
    <div class="sec-header">
      <div class="sec-header-copy">
        <div class="sec-title">Todos os produtos</div>
      </div>
    </div>
    <div class="products-grid cols4 is-stack-mobile">
      {% for product in products_by_creation %}
        {% render 'product-card', product: product %}
      {% else %}
        <div class="content-card collection-empty">
          <p>Nenhum produto encontrado nesta coleção.</p>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Coleção",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alinhamento dos textos",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Visibilidade"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Ocultar no mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Ocultar no desktop",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Título",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Todos os produtos"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Tamanho do título no desktop",
          "min": 18,
          "max": 48,
          "step": 1,
          "unit": "px",
          "default": 26
        },
        {
          "type": "range",
          "id": "title_size_mobile",
          "label": "Tamanho do título no mobile",
          "min": 18,
          "max": 48,
          "step": 1,
          "unit": "px",
          "default": 26
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo"
        },
        {
          "type": "range",
          "id": "subtitle_size",
          "label": "Tamanho do subtítulo no desktop",
          "min": 10,
          "max": 22,
          "step": 1,
          "unit": "px",
          "default": 13
        },
        {
          "type": "range",
          "id": "subtitle_size_mobile",
          "label": "Tamanho do subtítulo no mobile",
          "min": 10,
          "max": 22,
          "step": 1,
          "unit": "px",
          "default": 13
        },
        {
          "type": "checkbox",
          "id": "show_product_count",
          "label": "Mostrar quantidade de produtos",
          "default": false
        }
      ]
    },
    {
      "type": "products",
      "name": "Produtos",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "columns_desktop",
          "label": "Colunas no desktop",
          "options": [
            {
              "value": "2",
              "label": "2"
            },
            {
              "value": "3",
              "label": "3"
            },
            {
              "value": "4",
              "label": "4"
            }
          ],
          "default": "4"
        },
        {
          "type": "checkbox",
          "id": "show_media",
          "label": "Exibe a mídia do produto principal",
          "default": true
        },
        {
          "type": "select",
          "id": "media_ratio",
          "label": "Proporção",
          "options": [
            {
              "value": "adapt",
              "label": "Automático"
            },
            {
              "value": "portrait",
              "label": "Retrato"
            },
            {
              "value": "square",
              "label": "Quadrado"
            },
            {
              "value": "landscape",
              "label": "Paisagem"
            }
          ],
          "default": "adapt"
        },
        {
          "type": "header",
          "content": "Bordas"
        },
        {
          "type": "select",
          "id": "border_style",
          "label": "Estilo",
          "options": [
            {
              "value": "none",
              "label": "Nenhum"
            },
            {
              "value": "solid",
              "label": "Sólido"
            }
          ],
          "default": "none"
        },
        {
          "type": "range",
          "id": "corner_radius",
          "label": "Raio do canto",
          "min": 0,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coleção",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "products"
        }
      ]
    }
  ]
}
{% endschema %}
