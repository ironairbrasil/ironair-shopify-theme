{{ 'collection-page.css' | asset_url | stylesheet_tag }}
{{ 'featured-products.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

<section class="page page-stack shopify-padding-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  <div class="sec-header">
    <div class="sec-header-copy">
      <div class="sec-title">Todos os produtos</div>
      {% if section.settings.show_product_count %}
        <span class="sec-subtitle">{{ collection.products_count }} produto{% unless collection.products_count == 1 %}s{% endunless %}</span>
      {% endif %}
    </div>
  </div>
  <div class="products-grid cols4 is-stack-mobile">
    {% for product in collection.products %}
      {% render 'product-card', product: product %}
    {% else %}
      <div class="content-card collection-empty">
        <p>Nenhum produto encontrado nesta coleção.</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Coleção",
  "settings": [
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Mostrar quantidade de produtos",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ]
}
{% endschema %}
