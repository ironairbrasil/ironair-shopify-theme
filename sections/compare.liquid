{{ 'compare.css' | asset_url | stylesheet_tag }}

<section class="compare-section section-anchor shopify-padding-section theme-text-align-{{ section.settings.text_alignment | default: 'left' }}{% if section.settings.hide_on_mobile %} theme-hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} theme-hide-desktop{% endif %}" id="comparativo" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% assign title_blocks = section.blocks | where: 'type', 'title' %}
  {% assign title_block = title_blocks.first %}
  {% if title_block != blank or section.settings.title != blank %}
    <div class="section-head">
      <div>
        <h2 class="responsive-font-size" style="--font-size-desktop: {{ title_block.settings.title_size | default: 30 }}px; --font-size-mobile: {{ title_block.settings.title_size_mobile | default: title_block.settings.title_size | default: 30 }}px;" {% if title_block != blank %}{{ title_block.shopify_attributes }}{% endif %}>{{ title_block.settings.title | default: section.settings.title }}</h2>
      </div>
    </div>
  {% endif %}
  <p class="compare-hint">Arraste para o lado para ver as informações <span aria-hidden="true">→</span></p>
  <div class="compare-scroll">
    <table class="ctable">
      <thead>
        <tr>
          <th>Característica</th>
          <th class="hl">⚡ Iron Air</th>
          <th>Ferro tradicional</th>
          <th>Vaporizador vertical</th>
        </tr>
      </thead>
      <tbody>
        {% for block in section.blocks %}
          {% if block.type == 'title' %}{% continue %}{% endif %}
          <tr {{ block.shopify_attributes }}>
            <td>{{ block.settings.label }}</td>
            <td class="hl"><span class="{{ block.settings.iron_air }}">{{ block.settings.iron_air | replace: 'yes', '✓' | replace: 'no', '✗' | replace: 'mid', '—' }}</span></td>
            <td><span class="{{ block.settings.traditional }}">{{ block.settings.traditional | replace: 'yes', '✓' | replace: 'no', '✗' | replace: 'mid', '—' }}</span></td>
            <td><span class="{{ block.settings.steamer }}">{{ block.settings.steamer | replace: 'yes', '✓' | replace: 'no', '✗' | replace: 'mid', '—' }}</span></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

{% schema %}
{
  "name": "Comparativo",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alinhamento dos textos",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Visibilidade"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Ocultar no mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Ocultar no desktop",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Título",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Compare e decida"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Tamanho do título no desktop",
          "min": 18,
          "max": 56,
          "step": 1,
          "unit": "px",
          "default": 30
        },
        {
          "type": "range",
          "id": "title_size_mobile",
          "label": "Tamanho do título no mobile",
          "min": 18,
          "max": 56,
          "step": 1,
          "unit": "px",
          "default": 30
        }
      ]
    },
    {
      "type": "row",
      "name": "Linha",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Característica",
          "default": "Passa automaticamente"
        },
        {
          "type": "select",
          "id": "iron_air",
          "label": "Iron Air",
          "default": "yes",
          "options": [
            {
              "value": "yes",
              "label": "Sim"
            },
            {
              "value": "no",
              "label": "Não"
            },
            {
              "value": "mid",
              "label": "Parcial"
            }
          ]
        },
        {
          "type": "select",
          "id": "traditional",
          "label": "Ferro",
          "default": "no",
          "options": [
            {
              "value": "yes",
              "label": "Sim"
            },
            {
              "value": "no",
              "label": "Não"
            },
            {
              "value": "mid",
              "label": "Parcial"
            }
          ]
        },
        {
          "type": "select",
          "id": "steamer",
          "label": "Vaporizador",
          "default": "no",
          "options": [
            {
              "value": "yes",
              "label": "Sim"
            },
            {
              "value": "no",
              "label": "Não"
            },
            {
              "value": "mid",
              "label": "Parcial"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparativo",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "row",
          "settings": {
            "label": "Passa automaticamente",
            "iron_air": "yes",
            "traditional": "no",
            "steamer": "no"
          }
        },
        {
          "type": "row",
          "settings": {
            "label": "Você pode fazer outra coisa",
            "iron_air": "yes",
            "traditional": "no",
            "steamer": "no"
          }
        },
        {
          "type": "row",
          "settings": {
            "label": "Sem risco de queimar roupas",
            "iron_air": "yes",
            "traditional": "no",
            "steamer": "yes"
          }
        },
        {
          "type": "row",
          "settings": {
            "label": "Elimina vincos profundos",
            "iron_air": "yes",
            "traditional": "yes",
            "steamer": "no"
          }
        },
        {
          "type": "row",
          "settings": {
            "label": "Design compacto",
            "iron_air": "yes",
            "traditional": "mid",
            "steamer": "no"
          }
        },
        {
          "type": "row",
          "settings": {
            "label": "Garantia de 1 ano",
            "iron_air": "yes",
            "traditional": "mid",
            "steamer": "mid"
          }
        }
      ]
    }
  ]
}
{% endschema %}
