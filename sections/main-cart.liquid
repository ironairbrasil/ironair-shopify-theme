{{ 'cart.css' | asset_url | stylesheet_tag }}
{{ 'cart.js' | asset_url | script_tag }}

<section class="page page-stack shopify-padding-section theme-text-align-{{ section.settings.text_alignment | default: 'left' }} theme-mobile-text-align-{{ section.settings.mobile_text_alignment | default: section.settings.text_alignment | default: 'left' }} theme-content-align-{{ section.settings.content_alignment | default: section.settings.text_alignment | default: 'left' }} theme-mobile-content-align-{{ section.settings.mobile_content_alignment | default: section.settings.content_alignment | default: section.settings.mobile_text_alignment | default: section.settings.text_alignment | default: 'left' }}{% if section.settings.hide_on_mobile %} theme-hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} theme-hide-desktop{% endif %}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  <div class="content-card">
    <h1>Carrinho</h1>
    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" class="cart-page-form">
        <div class="cart-page-items">
          {% for item in cart.items %}
            {% render 'cart-item', item: item %}
          {% endfor %}
        </div>
        <div class="cart-page-summary">
          <strong>Total: {{ cart.total_price | money }}</strong>
          <div class="cart-footer-actions">
            <button class="btn-hero-ghost" type="submit">Atualizar</button>
            <a class="btn-hero" href="https://ironair-payments.vercel.app/checkout-ironair?source=cart{% render 'ironair-checkout-prefill' %}" data-cart-checkout>Finalizar compra</a>
          </div>
        </div>
      </form>
    {% else %}
      <p>Seu carrinho está vazio.</p>
      <a class="btn-hero" href="{{ routes.all_products_collection_url }}">Ver produtos</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Carrinho",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alinhamento dos textos no desktop",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "Alinhamento dos textos no mobile",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Alinhamento do conteúdo no desktop",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "label": "Alinhamento do conteúdo no mobile",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Visibilidade"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Ocultar no mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Ocultar no desktop",
      "default": false
    }
  ]
}
{% endschema %}
