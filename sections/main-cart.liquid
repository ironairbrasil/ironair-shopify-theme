{{ 'cart.css' | asset_url | stylesheet_tag }}
{{ 'cart.js' | asset_url | script_tag }}

<section class="page page-stack shopify-padding-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  <div class="content-card">
    <h1>Carrinho</h1>
    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" class="cart-page-form">
        <div class="cart-page-items">
          {% for item in cart.items %}
            {% render 'cart-item', item: item %}
          {% endfor %}
        </div>
        <div class="cart-page-summary">
          <strong>Total: {{ cart.total_price | money }}</strong>
          <div class="cart-footer-actions">
            <button class="btn-hero-ghost" type="submit">Atualizar</button>
            <button class="btn-hero" type="submit" name="checkout">Finalizar compra</button>
          </div>
        </div>
      </form>
    {% else %}
      <p>Seu carrinho está vazio.</p>
      <a class="btn-hero" href="{{ routes.all_products_collection_url }}">Ver produtos</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Carrinho",
  "settings": [
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ]
}
{% endschema %}
