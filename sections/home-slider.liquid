{{ 'home-slider.css' | asset_url | stylesheet_tag }}

{% assign text_blocks = section.blocks | where: 'type', 'text' %}
{% assign button_blocks = section.blocks | where: 'type', 'button' %}

<section class="home-slider shopify-padding-section" aria-label="{{ section.settings.aria_label }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  <div class="home-slider-stage media-height-auto content-{{ section.settings.content_position }} text-{{ section.settings.text_alignment }}">
    <article class="home-slide tone-{{ section.settings.tone }} {% if section.settings.mobile_image != blank or section.settings.mobile_video != blank %}has-mobile-media{% endif %} is-active" aria-hidden="false">
      <div class="home-slide-media">
        {% if section.settings.background_mode == 'video' %}
          {% if section.settings.video != blank %}
            {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '2400x', class: 'home-slide-video is-desktop-media' }}
          {% endif %}
          {% if section.settings.mobile_video != blank %}
            {{ section.settings.mobile_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '1200x', class: 'home-slide-video is-mobile-media' }}
          {% endif %}
        {% else %}
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 2400 | image_tag: alt: section.settings.aria_label, class: 'home-slide-image is-desktop-media', loading: 'eager' }}
          {% endif %}
          {% if section.settings.mobile_image != blank %}
            {{ section.settings.mobile_image | image_url: width: 1200 | image_tag: alt: section.settings.aria_label, class: 'home-slide-image is-mobile-media', loading: 'eager' }}
          {% endif %}
        {% endif %}
      </div>
      <div class="home-slide-overlay"></div>
    </article>

    <div class="home-slide-content">
      {% if text_blocks.size > 0 or button_blocks.size > 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'text' %}
            <div
              class="home-slide-copy copy-size-{{ block.settings.text_width | default: block.settings.text_size | default: 'large' }}"
              style="--hero-heading-size: {{ block.settings.heading_size | default: 52 }}px; --hero-text-size: {{ block.settings.description_size | default: 16 }}px;"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.heading != blank %}
                <h2>{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="home-slide-text">{{ block.settings.text }}</div>
              {% endif %}
            </div>
          {% endif %}

          {% if block.type == 'button' and block.settings.label != blank %}
            <div class="home-slide-actions" style="--hero-button-size: {{ block.settings.label_size | default: 14 }}px;" {{ block.shopify_attributes }}>
              <a
                class="home-slide-button is-{{ block.settings.style }}"
                href="{{ block.settings.url | default: routes.all_products_collection_url }}"
                {% if block.settings.new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
              >
                {{ block.settings.label }}
              </a>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="home-slide-copy copy-size-large">
          <h2>Adicione texto ao seu hero</h2>
          <div class="home-slide-text"><p>Use blocos de texto e botão para montar a chamada.</p></div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Rótulo acessível",
      "default": "Hero principal da Iron Air"
    },
    {
      "type": "select",
      "id": "background_mode",
      "label": "Plano de fundo",
      "default": "image",
      "options": [
        {
          "value": "image",
          "label": "Imagem"
        },
        {
          "value": "video",
          "label": "Vídeo"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem de fundo",
      "visible_if": "{{ section.settings.background_mode == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Imagem de fundo no celular",
      "visible_if": "{{ section.settings.background_mode == 'image' }}"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Vídeo de fundo",
      "visible_if": "{{ section.settings.background_mode == 'video' }}"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Vídeo de fundo no celular",
      "visible_if": "{{ section.settings.background_mode == 'video' }}"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Posição do conteúdo",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alinhamento do texto",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "select",
      "id": "tone",
      "label": "Cor de fundo",
      "default": "navy",
      "options": [
        {
          "value": "navy",
          "label": "Azul"
        },
        {
          "value": "gold",
          "label": "Dourado"
        },
        {
          "value": "teal",
          "label": "Verde"
        },
        {
          "value": "dark",
          "label": "Escuro"
        }
      ]
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Texto",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Adicione texto ao seu hero"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Descrição",
          "default": "<p>Use blocos de texto e botão para montar a chamada.</p>"
        },
        {
          "type": "range",
          "id": "heading_size",
          "label": "Tamanho do título",
          "min": 24,
          "max": 88,
          "step": 1,
          "unit": "px",
          "default": 52
        },
        {
          "type": "range",
          "id": "description_size",
          "label": "Tamanho da descrição",
          "min": 12,
          "max": 28,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "select",
          "id": "text_width",
          "label": "Largura",
          "default": "large",
          "options": [
            {
              "value": "small",
              "label": "Pequena"
            },
            {
              "value": "medium",
              "label": "Média"
            },
            {
              "value": "large",
              "label": "Grande"
            }
          ]
        }
      ]
    },
    {
      "type": "button",
      "name": "Botão",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "default": "Comprar agora"
        },
        {
          "type": "range",
          "id": "label_size",
          "label": "Tamanho do texto",
          "min": 11,
          "max": 22,
          "step": 1,
          "unit": "px",
          "default": 14
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Estilo",
          "default": "primary",
          "options": [
            {
              "value": "primary",
              "label": "Principal"
            },
            {
              "value": "secondary",
              "label": "Secundário"
            },
            {
              "value": "light",
              "label": "Claro"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "new_tab",
          "label": "Abrir em nova aba",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
