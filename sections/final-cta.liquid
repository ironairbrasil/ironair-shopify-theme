{{ 'final-cta.css' | asset_url | stylesheet_tag }}

{% assign featured_product = section.settings.product %}
{% assign featured_variant = featured_product.selected_or_first_available_variant %}
{% if featured_variant %}
  {% assign featured_price = featured_variant.price %}
  {% assign featured_compare_price = featured_variant.compare_at_price %}
  {% assign featured_pix_price = featured_price | times: 90 | divided_by: 100 %}
  {% assign featured_installments = featured_price | divided_by: 12 %}
  {% if featured_compare_price > featured_price %}
    {% assign featured_discount = featured_compare_price | minus: featured_price | times: 100 | divided_by: featured_compare_price %}
  {% endif %}
{% endif %}

<section class="final-cta shopify-padding-section theme-text-align-{{ section.settings.text_alignment | default: 'left' }} theme-mobile-text-align-{{ section.settings.mobile_text_alignment | default: section.settings.text_alignment | default: 'left' }} theme-content-align-{{ section.settings.content_alignment | default: section.settings.text_alignment | default: 'left' }} theme-mobile-content-align-{{ section.settings.mobile_content_alignment | default: section.settings.content_alignment | default: section.settings.mobile_text_alignment | default: section.settings.text_alignment | default: 'left' }}{% if section.settings.hide_on_mobile %} theme-hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} theme-hide-desktop{% endif %}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% assign title_blocks = section.blocks | where: 'type', 'title' %}
  {% assign title_block = title_blocks.first %}
  <div class="fc-left">
    {% if title_block != blank or section.settings.title != blank %}
      <h2 class="responsive-font-size theme-block-align-{{ title_block.settings.block_text_alignment | default: 'inherit' }} theme-block-mobile-align-{{ title_block.settings.block_mobile_text_alignment | default: title_block.settings.block_text_alignment | default: 'inherit' }}" style="--font-size-desktop: {{ title_block.settings.title_size | default: 52 }}px; --font-size-mobile: {{ title_block.settings.title_size_mobile | default: title_block.settings.title_size | default: 52 }}px;" {% if title_block != blank %}{{ title_block.shopify_attributes }}{% endif %}>{{ title_block.settings.title | default: section.settings.title | newline_to_br }}</h2>
    {% endif %}
    {% if title_block.settings.text != blank or section.settings.text != blank %}
      <p class="responsive-font-size theme-block-align-{{ title_block.settings.block_text_alignment | default: 'inherit' }} theme-block-mobile-align-{{ title_block.settings.block_mobile_text_alignment | default: title_block.settings.block_text_alignment | default: 'inherit' }}" style="--font-size-desktop: {{ title_block.settings.text_size | default: 14 }}px; --font-size-mobile: {{ title_block.settings.text_size_mobile | default: title_block.settings.text_size | default: 14 }}px;">{{ title_block.settings.text | default: section.settings.text }}</p>
    {% endif %}
    <div class="final-points">
      {% for block in section.blocks %}
        {% if block.type == 'title' %}{% continue %}{% endif %}
        <div class="theme-block-align-{{ block.settings.block_text_alignment | default: 'inherit' }} theme-block-mobile-align-{{ block.settings.block_mobile_text_alignment | default: block.settings.block_text_alignment | default: 'inherit' }}" {{ block.shopify_attributes }}>✓ {{ block.settings.text }}</div>
      {% endfor %}
    </div>
  </div>
  <div class="fc-right">
    {% if featured_discount %}
      <div class="fc-off-tag">{{ featured_discount }}% OFF</div>
    {% endif %}
    {% if featured_compare_price > featured_price %}
      <div class="fc-old">De {{ featured_compare_price | money }}</div>
    {% endif %}
    <div class="fc-price">
      {% if featured_variant %}
        {{ featured_pix_price | money }}
      {% else %}
        R$ 269,00
      {% endif %}
    </div>
    {% if featured_variant %}
      <div class="product-card-payment-pix">com 10% OFF no Pix</div>
    {% endif %}
    <div class="fc-parcel">
      {% if featured_variant %}
        ou {{ featured_price | money }} em até <strong>12x de {{ featured_installments | money }}</strong> sem juros
      {% else %}
        ou 12x de <strong>R$ 22,42</strong> sem juros
      {% endif %}
    </div>
    {% if featured_variant and featured_product.has_only_default_variant %}
      {% assign featured_checkout_image = featured_product.featured_image %}
      {% if featured_variant.featured_image %}
        {% assign featured_checkout_image = featured_variant.featured_image %}
      {% endif %}
      {% if featured_product.featured_image %}
        {% assign featured_product_checkout_image_url = featured_product.featured_image | image_url: width: 400 %}
      {% endif %}
      <form method="post" action="{{ routes.cart_add_url }}" data-ironair-checkout data-product-handle="{{ featured_product.handle | escape }}" data-product-title="{{ featured_product.title | escape }}" {% if featured_product_checkout_image_url %}data-product-image="{{ featured_product_checkout_image_url }}"{% endif %}>
        <input type="hidden" name="id" value="{{ featured_variant.id }}" data-variant-gid="gid://shopify/ProductVariant/{{ featured_variant.id }}" data-price-cents="{{ featured_variant.price }}" data-product-title="{{ featured_product.title | escape }}" {% if featured_checkout_image %}data-product-image="{{ featured_checkout_image | image_url: width: 400 }}"{% endif %}>
        <button class="fc-btn" type="submit">🛒 {{ section.settings.button_label }}</button>
      </form>
    {% elsif featured_product != blank %}
      <a class="fc-btn" href="{{ featured_product.url }}">Escolher opção</a>
    {% else %}
      <a class="fc-btn" href="/admin/products">Conecte o produto</a>
    {% endif %}
    <div class="fc-trust">
      <div class="fc-trust-item">🔒 Pagamento seguro</div>
      <div class="fc-trust-item">🚚 Frete grátis</div>
      <div class="fc-trust-item">↩ 30 dias de troca</div>
    </div>
  </div>
</section>

