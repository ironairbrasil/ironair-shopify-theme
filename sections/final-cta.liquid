{{ 'final-cta.css' | asset_url | stylesheet_tag }}

{% assign featured_product = section.settings.product %}
{% assign featured_variant = featured_product.selected_or_first_available_variant %}
{% if featured_variant %}
  {% assign featured_price = featured_variant.price %}
  {% assign featured_compare_price = featured_variant.compare_at_price %}
  {% assign featured_pix_price = featured_price | times: 90 | divided_by: 100 %}
  {% assign featured_installments = featured_price | divided_by: 12 %}
  {% if featured_compare_price > featured_price %}
    {% assign featured_discount = featured_compare_price | minus: featured_price | times: 100 | divided_by: featured_compare_price %}
  {% endif %}
{% endif %}

<section class="final-cta shopify-padding-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% assign title_blocks = section.blocks | where: 'type', 'title' %}
  {% assign title_block = title_blocks.first %}
  <div class="fc-left">
    {% if title_block != blank or section.settings.title != blank %}
      <h2 style="font-size: {{ title_block.settings.title_size | default: 52 }}px;" {% if title_block != blank %}{{ title_block.shopify_attributes }}{% endif %}>{{ title_block.settings.title | default: section.settings.title | newline_to_br }}</h2>
    {% endif %}
    {% if title_block.settings.text != blank or section.settings.text != blank %}
      <p style="font-size: {{ title_block.settings.text_size | default: 14 }}px;">{{ title_block.settings.text | default: section.settings.text }}</p>
    {% endif %}
    <div class="final-points">
      {% for block in section.blocks %}
        {% if block.type == 'title' %}{% continue %}{% endif %}
        <div {{ block.shopify_attributes }}>✓ {{ block.settings.text }}</div>
      {% endfor %}
    </div>
  </div>
  <div class="fc-right">
    {% if featured_discount %}
      <div class="fc-off-tag">{{ featured_discount }}% OFF</div>
    {% endif %}
    {% if featured_compare_price > featured_price %}
      <div class="fc-old">De {{ featured_compare_price | money }}</div>
    {% endif %}
    <div class="fc-price">
      {% if featured_variant %}
        {{ featured_pix_price | money }}
      {% else %}
        R$ 269,00
      {% endif %}
    </div>
    {% if featured_variant %}
      <div class="product-card-payment-pix">com 10% OFF no Pix</div>
    {% endif %}
    <div class="fc-parcel">
      {% if featured_variant %}
        ou {{ featured_price | money }} em até <strong>12x de {{ featured_installments | money }}</strong> sem juros
      {% else %}
        ou 12x de <strong>R$ 22,42</strong> sem juros
      {% endif %}
    </div>
    {% if featured_variant and featured_product.has_only_default_variant %}
      <form method="post" action="{{ routes.cart_add_url }}">
        <input type="hidden" name="id" value="{{ featured_variant.id }}">
        <button class="fc-btn" type="submit">🛒 {{ section.settings.button_label }}</button>
      </form>
    {% elsif featured_product != blank %}
      <a class="fc-btn" href="{{ featured_product.url }}">Escolher opção</a>
    {% else %}
      <a class="fc-btn" href="/admin/products">Conecte o produto</a>
    {% endif %}
    <div class="fc-trust">
      <div class="fc-trust-item">🔒 Pagamento seguro</div>
      <div class="fc-trust-item">🚚 Frete grátis</div>
      <div class="fc-trust-item">↩ 30 dias de troca</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA final",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Produto principal"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Botão",
      "default": "Comprar agora com desconto"
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Título",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "title",
          "label": "Título",
          "default": "Pare de perder tempo\npassando roupa"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Tamanho do título",
          "min": 24,
          "max": 72,
          "step": 1,
          "unit": "px",
          "default": 52
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "O Iron Air passa, seca e desamassa automaticamente para deixar sua rotina mais leve, rápida e prática todos os dias."
        },
        {
          "type": "range",
          "id": "text_size",
          "label": "Tamanho do texto",
          "min": 12,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 14
        }
      ]
    },
    {
      "type": "point",
      "name": "Benefício",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Frete grátis"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CTA final",
      "blocks": [
        {
          "type": "point",
          "settings": {
            "text": "Frete grátis"
          }
        },
        {
          "type": "point",
          "settings": {
            "text": "12x sem juros"
          }
        },
        {
          "type": "point",
          "settings": {
            "text": "30 dias de garantia"
          }
        }
      ]
    }
  ]
}
{% endschema %}
