{{ 'how-it-works.css' | asset_url | stylesheet_tag }}

<section class="hiw-section section-anchor shopify-padding-section theme-text-align-{{ section.settings.text_alignment | default: 'left' }}{% if section.settings.hide_on_mobile %} theme-hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} theme-hide-desktop{% endif %}" id="como-funciona" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% assign title_blocks = section.blocks | where: 'type', 'title' %}
  {% assign title_block = title_blocks.first %}
  {% if title_block != blank or section.settings.title != blank %}
    <div class="section-head">
      <div>
        <h2 class="responsive-font-size" style="--font-size-desktop: {{ title_block.settings.title_size | default: 30 }}px; --font-size-mobile: {{ title_block.settings.title_size_mobile | default: title_block.settings.title_size | default: 30 }}px;" {% if title_block != blank %}{{ title_block.shopify_attributes }}{% endif %}>{{ title_block.settings.title | default: section.settings.title }}</h2>
      </div>
    </div>
  {% endif %}
  <div class="hiw-steps">
    {% for block in section.blocks %}
      {% if block.type == 'title' %}{% continue %}{% endif %}
      {% assign fallback_asset = 'passo-1.jpg' %}
      {% if forloop.index == 2 %}{% assign fallback_asset = 'passo-2.jpg' %}{% endif %}
      {% if forloop.index == 3 %}{% assign fallback_asset = 'passo-3.jpg' %}{% endif %}
      {% if forloop.index == 4 %}{% assign fallback_asset = 'passo-4.jpg' %}{% endif %}
      <div class="hiw-step" {{ block.shopify_attributes }}>
        <div class="hiw-media">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 320 | image_tag: alt: block.settings.title, class: 'hiw-media-image', loading: 'lazy' }}
          {% else %}
            <img class="hiw-media-image" src="{{ fallback_asset | asset_url }}" alt="{{ block.settings.title | escape }}">
          {% endif %}
        </div>
        <div class="hiw-title">{{ block.settings.title }}</div>
        <div class="hiw-desc">{{ block.settings.description }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Como funciona",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alinhamento dos textos",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Visibilidade"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Ocultar no mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Ocultar no desktop",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Título",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Como funciona"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Tamanho do título no desktop",
          "min": 18,
          "max": 56,
          "step": 1,
          "unit": "px",
          "default": 30
        },
        {
          "type": "range",
          "id": "title_size_mobile",
          "label": "Tamanho do título no mobile",
          "min": 18,
          "max": 56,
          "step": 1,
          "unit": "px",
          "default": 30
        }
      ]
    },
    {
      "type": "step",
      "name": "Passo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Coloque a roupa"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrição",
          "default": "Prenda sua camisa, calça ou vestido no balão. Leva menos de 30 segundos."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Como funciona",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "step",
          "settings": {
            "title": "Coloque a roupa",
            "description": "Prenda sua camisa, calça ou vestido no balão. Leva menos de 30 segundos."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Ajuste as configurações",
            "description": "Coloque no modo ferro, acerte o tempo e temperatura pelo painel digital."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Relaxe enquanto aguarda",
            "description": "O Iron Air assume. Faça outras coisas enquanto a roupa fica pronta."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Vista e saia",
            "description": "Em 10 a 12 minutos suas roupas estão lisas, secas e prontas para vestir."
          }
        }
      ]
    }
  ]
}
{% endschema %}
