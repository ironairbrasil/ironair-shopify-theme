<section class="page page-stack custom-liquid-section shopify-padding-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% if section.settings.title != blank %}
    <div class="section-head">
      <div>
        <h1>{{ section.settings.title }}</h1>
      </div>
    </div>
  {% endif %}
  {% if section.settings.custom_liquid != blank and section.settings.custom_liquid != '<p>Adicione seu conteúdo.</p>' %}
    <div class="custom-liquid-content">
      {{ section.settings.custom_liquid }}
    </div>
  {% endif %}
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'text' %}
        {% if block.settings.heading != blank or block.settings.text != blank %}
          <div
            class="custom-liquid-block custom-liquid-text copy-size-{{ block.settings.text_width | default: block.settings.text_size | default: 'large' }}"
            style="--hero-heading-size: {{ block.settings.heading_size | default: 52 }}px; --hero-heading-mobile-size: {{ block.settings.heading_size_mobile | default: block.settings.heading_size | default: 52 }}px; --hero-text-size: {{ block.settings.description_size | default: 16 }}px; --hero-text-mobile-size: {{ block.settings.description_size_mobile | default: block.settings.description_size | default: 16 }}px;"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.heading != blank %}
              <h2>{{ block.settings.heading }}</h2>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="custom-liquid-text-copy">{{ block.settings.text }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% when 'image' %}
        {% if block.settings.image != blank %}
          <div class="custom-liquid-block custom-liquid-image" {{ block.shopify_attributes }}>
            {{ block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: block.settings.alt }}
          </div>
        {% endif %}
      {% when 'button' %}
        {% if block.settings.label != blank %}
          <div class="custom-liquid-block" {{ block.shopify_attributes }}>
            <a class="btn-hero" href="{{ block.settings.url | default: routes.root_url }}">{{ block.settings.label }}</a>
          </div>
        {% endif %}
      {% when 'video' %}
        {% if block.settings.video_url != blank %}
          <div class="custom-liquid-block custom-liquid-video" {{ block.shopify_attributes }}>
            <video controls src="{{ block.settings.video_url }}"></video>
          </div>
        {% endif %}
      {% when 'custom_liquid' %}
        {% if block.settings.custom_liquid != blank %}
          <div class="custom-liquid-block" {{ block.shopify_attributes }}>
            {{ block.settings.custom_liquid }}
          </div>
        {% endif %}
      {% when 'product_vendor', 'product_title', 'product_badge', 'product_rating', 'product_description', 'product_price', 'product_variant_picker', 'product_buy_button', 'product_stock', 'product_benefits', 'product_upsells' %}
        <div class="custom-liquid-block">
          {% render 'custom-product-block', block: block %}
        </div>
    {% endcase %}
  {% endfor %}
</section>

{% schema %}
{
  "name": "Liquid customizado",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título"
    },
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "Liquid"
