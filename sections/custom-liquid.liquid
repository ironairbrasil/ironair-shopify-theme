<section class="page page-stack custom-liquid-section shopify-padding-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% if section.settings.title != blank %}
    <div class="section-head">
      <div>
        {% if section.settings.kicker != blank %}<div class="section-kicker">{{ section.settings.kicker }}</div>{% endif %}
        <h1>{{ section.settings.title }}</h1>
      </div>
    </div>
  {% endif %}
  <div class="content-card custom-liquid-content">
    {{ section.settings.custom_liquid }}
  </div>
  {% content_for 'blocks' %}
</section>

{% schema %}
{
  "name": "Liquid customizado",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Selo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título"
    },
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "Liquid",
      "default": "<p>Adicione seu conteúdo.</p>"
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Liquid customizado"
    }
  ]
}
{% endschema %}
