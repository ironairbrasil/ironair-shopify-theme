          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Adicione texto ao seu hero"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Descrição",
          "default": "<p>Use blocos de texto e botão para montar a chamada.</p>"
        },
        {
          "type": "range",
          "id": "heading_size",
          "label": "Tamanho do título no desktop",
          "min": 24,
          "max": 88,
          "step": 1,
          "unit": "px",
          "default": 52
        },
        {
          "type": "range",
          "id": "heading_size_mobile",
          "label": "Tamanho do título no mobile",
          "min": 24,
          "max": 88,
          "step": 1,
          "unit": "px",
          "default": 52
        },
        {
          "type": "range",
          "id": "description_size",
          "label": "Tamanho da descrição no desktop",
          "min": 12,
          "max": 28,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "range",
          "id": "description_size_mobile",
          "label": "Tamanho da descrição no mobile",
          "min": 12,
          "max": 28,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "select",
          "id": "text_width",
          "label": "Largura",
          "default": "large",
          "options": [
            {
              "value": "small",
              "label": "Pequena"
            },
            {
              "value": "medium",
              "label": "Média"
            },
            {
              "value": "large",
              "label": "Grande"
            }
          ]
        }
      ]
    },
    {
      "type": "image",
      "name": "Imagem",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Texto alternativo"
        }
      ]
    },
    {
      "type": "button",
      "name": "Botão",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "default": "Comprar"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    },
    {
      "type": "video",
      "name": "Vídeo",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "URL do vídeo"
        }
      ]
    },
    {
      "type": "custom_liquid",
      "name": "Liquid personalizado",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Liquid"
        }
      ]
    },
    {
      "type": "product_benefits",
      "name": "Benefícios do produto",
      "settings": [
        {
          "type": "text",
          "id": "benefit_1",
          "label": "Benefício 1",
          "default": "✓ Frete grátis"
        },
        {
          "type": "text",
          "id": "benefit_2",
          "label": "Benefício 2",
          "default": "✓ Checkout Shopify seguro"
        },
        {
          "type": "text",
          "id": "benefit_3",
          "label": "Benefício 3"
        }
      ]
    },
    {
