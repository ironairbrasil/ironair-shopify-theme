    {
      "type": "product_description",
      "name": "Descrição do produto",
      "settings": []
    },
    {
      "type": "product_price",
      "name": "Preço do produto",
      "settings": []
    },
    {
      "type": "product_variant_picker",
      "name": "Variantes do produto",
      "settings": []
    },
    {
      "type": "product_buy_button",
      "name": "Botão de compra",
