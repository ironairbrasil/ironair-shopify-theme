{{ 'header.css' | asset_url | stylesheet_tag }}
{{ 'navigation.css' | asset_url | stylesheet_tag }}

{% assign has_header_block = false %}

{% for block in section.blocks %}
  {% case block.type %}
    {% when 'announcement_bar' %}
      {% if block.settings.text != blank %}
        <div class="topbar" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
      {% endif %}

    {% when 'header_main' %}
      {% assign has_header_block = true %}
      {% assign menu_links = block.settings.menu.links %}

      <div class="header-shell" data-ironair-header {{ block.shopify_attributes }}>
        <header>
          <div class="header-inner">
            <button type="button" class="mobile-menu-toggle" data-mobile-menu-toggle aria-label="Abrir menu" aria-expanded="false">
              {% render 'icon', icon: 'menu' %}
            </button>

            <a href="{{ routes.root_url }}" class="logo">
              {% if block.settings.logo != blank %}
                {{ block.settings.logo | image_url: width: 520 | image_tag: alt: shop.name, loading: 'eager' }}
              {% else %}
                <img src="{{ 'logo-1.png' | asset_url }}" alt="{{ shop.name }}" width="180" height="52">
              {% endif %}
            </a>

            {% if block.settings.search_enabled %}
              <form action="{{ routes.search_url }}" method="get" class="header-search" role="search">
                <div class="header-search-bar">
                  <input name="q" type="search" value="{{ search.terms | escape }}" placeholder="{{ block.settings.search_placeholder }}">
                  <button type="submit" aria-label="{{ block.settings.search_button_label }}">{% render 'icon', icon: 'search' %}</button>
                </div>
              </form>
            {% endif %}

            <div class="header-icons header-icons-desktop">
              {% if block.settings.account_enabled %}
                <a class="hicon" href="{{ routes.account_url }}" aria-label="{{ block.settings.account_label }}">
                  {% render 'icon', icon: 'account' %}
                  {% if block.settings.show_icon_labels %}<span class="hicon-label">{{ block.settings.account_label }}</span>{% endif %}
                </a>
              {% endif %}

              {% if block.settings.cart_enabled %}
                <button type="button" class="hicon js-cart-drawer-open" aria-controls="CartDrawer" aria-expanded="false" aria-label="{{ block.settings.cart_label }}">
                  {% render 'icon', icon: 'cart' %}
                  {% if block.settings.show_icon_labels %}
                    <span class="hicon-label">{{ block.settings.cart_label }} <span class="badge" data-cart-count>{{ cart.item_count }}</span></span>
                  {% else %}
                    <span class="badge" data-cart-count>{{ cart.item_count }}</span>
                  {% endif %}
                </button>
              {% endif %}
            </div>

            <div class="mobile-header-actions">
              <button type="button" class="hicon mobile-header-action mobile-cart-button js-cart-drawer-open" aria-controls="CartDrawer" aria-expanded="false" aria-label="{{ block.settings.cart_label }}">
                {% render 'icon', icon: 'cart' %}
                <span class="mobile-cart-badge" data-cart-count>{{ cart.item_count }}</span>
              </button>
            </div>
          </div>
        </header>

        {% if menu_links.size > 0 %}
          <nav class="navcat" aria-label="{{ block.settings.menu_label }}">
            <div class="navcat-inner navcat-position-{{ block.settings.menu_position }}">
              {% for link in menu_links %}
                <a class="navcat-item {% if link.current %}active{% endif %}" href="{{ link.url }}">
                  {{ link.title }}
                </a>
              {% endfor %}
            </div>
          </nav>
        {% endif %}
      </div>

      <button type="button" class="mobile-nav-overlay" data-mobile-menu-close aria-label="Fechar menu"></button>
      <aside id="mobile-nav-sidebar" class="mobile-nav-sidebar" data-mobile-sidebar aria-hidden="true">
        <div class="mobile-nav-sidebar-header">
          <div>
            <strong>Menu</strong>
            <span>Navegue pelas principais áreas da loja</span>
          </div>
          <button type="button" class="cart-close" data-mobile-menu-close aria-label="Fechar menu">x</button>
        </div>
        <div class="mobile-nav-sidebar-body">
          {% for link in menu_links %}
            <a class="mobile-nav-link {% if link.current %}active{% endif %}" href="{{ link.url }}">
              <span>{{ link.title }}</span>
            </a>
          {% endfor %}
        </div>
      </aside>

    {% when 'custom_liquid' %}
      {% if block.settings.custom_liquid != blank %}
        <div class="header-custom-liquid" {{ block.shopify_attributes }}>
          {{ block.settings.custom_liquid }}
        </div>
      {% endif %}
  {% endcase %}
{% endfor %}

{% unless has_header_block %}
  <div class="header-shell" data-ironair-header>
    <header>
      <div class="header-inner">
        <button type="button" class="mobile-menu-toggle" data-mobile-menu-toggle aria-label="Abrir menu" aria-expanded="false">
          {% render 'icon', icon: 'menu' %}
        </button>
        <a href="{{ routes.root_url }}" class="logo">
          <img src="{{ 'logo-1.png' | asset_url }}" alt="{{ shop.name }}" width="180" height="52">
        </a>
        <form action="{{ routes.search_url }}" method="get" class="header-search" role="search">
          <div class="header-search-bar">
            <input name="q" type="search" value="{{ search.terms | escape }}" placeholder="Buscar produtos...">
            <button type="submit" aria-label="Buscar">{% render 'icon', icon: 'search' %}</button>
          </div>
        </form>
        <div class="header-icons header-icons-desktop">
          <a class="hicon" href="{{ routes.account_url }}" aria-label="Conta">
            {% render 'icon', icon: 'account' %}
            <span class="hicon-label">Conta</span>
          </a>
          <button type="button" class="hicon js-cart-drawer-open" aria-controls="CartDrawer" aria-expanded="false" aria-label="Carrinho">
            {% render 'icon', icon: 'cart' %}
            <span class="hicon-label">Carrinho <span class="badge" data-cart-count>{{ cart.item_count }}</span></span>
          </button>
        </div>
      </div>
    </header>
  </div>
{% endunless %}

{% schema %}
{
  "name": "Cabeçalho Iron Air",
  "settings": [],
  "blocks": [
    {
      "type": "announcement_bar",
      "name": "Barra de anúncios",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "Texto", "default": "🚚 FRETE GRÁTIS em todo Brasil + 12X SEM JUROS no cartão + 10% OFF no Pix" }
      ]
    },
    {
      "type": "header_main",
      "name": "Cabeçalho",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "checkbox", "id": "search_enabled", "label": "Mostrar busca", "default": true },
        { "type": "text", "id": "search_placeholder", "label": "Placeholder da busca", "default": "Buscar produtos..." },
        { "type": "text", "id": "search_button_label", "label": "Rótulo do botão de busca", "default": "Buscar" },
        { "type": "checkbox", "id": "account_enabled", "label": "Mostrar conta", "default": true },
        { "type": "text", "id": "account_label", "label": "Texto da conta", "default": "Conta" },
        { "type": "checkbox", "id": "cart_enabled", "label": "Mostrar carrinho", "default": true },
        { "type": "text", "id": "cart_label", "label": "Texto do carrinho", "default": "Carrinho" },
        { "type": "checkbox", "id": "show_icon_labels", "label": "Mostrar texto dos ícones", "default": true },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
        { "type": "text", "id": "menu_label", "label": "Rótulo acessível do menu", "default": "Menu principal" },
        { "type": "select", "id": "menu_position", "label": "Posição do menu", "default": "center", "options": [
          { "value": "left", "label": "Esquerda" },
          { "value": "center", "label": "Centralizado" },
          { "value": "right", "label": "Direita" }
        ] }
      ]
    },
    {
      "type": "custom_liquid",
      "name": "Liquid personalizado",
      "limit": 1,
      "settings": [
        { "type": "liquid", "id": "custom_liquid", "label": "Liquid personalizado" }
      ]
    }
  ]
}
{% endschema %}
