{{ 'featured-products.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}
{{ 'featured-products.js' | asset_url | script_tag }}

{% assign selected_collection = section.settings.collection | default: collections.all %}
{% assign products_by_creation = selected_collection.products | sort: 'created_at' %}

<section class="section-anchor shopify-featured-product shopify-padding-section theme-text-align-{{ section.settings.text_alignment | default: 'left' }} theme-mobile-text-align-{{ section.settings.mobile_text_alignment | default: section.settings.text_alignment | default: 'left' }} theme-content-align-{{ section.settings.content_alignment | default: section.settings.text_alignment | default: 'left' }} theme-mobile-content-align-{{ section.settings.mobile_content_alignment | default: section.settings.content_alignment | default: section.settings.mobile_text_alignment | default: section.settings.text_alignment | default: 'left' }}{% if section.settings.hide_on_mobile %} theme-hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} theme-hide-desktop{% endif %}" id="produtos" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  <div class="section-head">
    <div>
      <h2>{{ section.settings.title }}</h2>
    </div>

    <a href="{{ routes.all_products_collection_url }}">
      {{ section.settings.link_label }}
    </a>
  </div>

  <div class="products-carousel-shell" data-products-carousel>
    <div class="products-carousel-nav" aria-label="Navegar produtos">
      <button type="button" class="products-carousel-arrow" data-products-prev aria-label="Produtos anteriores">‹</button>
      <button type="button" class="products-carousel-arrow" data-products-next aria-label="Próximos produtos">›</button>
    </div>

    <div class="products-grid is-carousel" data-products-track>
      {% for product in products_by_creation limit: 12 %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Produtos em destaque",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alinhamento dos textos no desktop",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "Alinhamento dos textos no mobile",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Alinhamento do conteúdo no desktop",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "label": "Alinhamento do conteúdo no mobile",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Nossos produtos"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link",
      "default": "Ver todos →"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção de produtos"
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Visibilidade"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Ocultar no mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Ocultar no desktop",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Produtos em destaque"
    }
  ]
}
{% endschema %}
