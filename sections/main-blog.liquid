{{ 'page.css' | asset_url | stylesheet_tag }}

<section class="page page-stack shopify-padding-section theme-text-align-{{ section.settings.text_alignment | default: 'left' }}{% if section.settings.hide_on_mobile %} theme-hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} theme-hide-desktop{% endif %}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  <div class="section-head">
    <div>
      <h1>{{ blog.title }}</h1>
    </div>
  </div>
  <div class="blog-list">
    {% for article in blog.articles %}
      <article class="content-card blog-article-card">
        <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
        <p>{{ article.excerpt_or_content | strip_html | truncate: 180 }}</p>
      </article>
    {% else %}
      <div class="content-card">Nenhum artigo publicado.</div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alinhamento dos textos",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ]
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Visibilidade"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Ocultar no mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Ocultar no desktop",
      "default": false
    }
  ]
}
{% endschema %}
