{{ 'collection-page.css' | asset_url | stylesheet_tag }}
{{ 'featured-products.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{% assign products_by_creation = collection.products | sort: 'created_at' %}

<section class="page page-stack shopify-padding-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'heading' %}
        <div class="sec-header" {{ block.shopify_attributes }}>
          <div class="sec-header-copy">
            <div class="sec-title" style="font-size: {{ block.settings.title_size | default: 26 }}px;">{{ block.settings.title | escape }}</div>
            {% if block.settings.show_product_count %}
              <span class="sec-subtitle" style="font-size: {{ block.settings.subtitle_size | default: 13 }}px;">{{ collection.products_count }} produto{% unless collection.products_count == 1 %}s{% endunless %}</span>
            {% elsif block.settings.subtitle != blank %}
              <span class="sec-subtitle" style="font-size: {{ block.settings.subtitle_size | default: 13 }}px;">{{ block.settings.subtitle | escape }}</span>
            {% endif %}
          </div>
        </div>

      {% when 'product_grid' %}
        <div class="products-grid cols{{ block.settings.columns_desktop }} is-stack-mobile" {{ block.shopify_attributes }}>
          {% for product in products_by_creation %}
            {% render 'product-card',
              product: product,
              show_media: block.settings.show_media,
              media_ratio: block.settings.media_ratio,
              border_style: block.settings.border_style,
              corner_radius: block.settings.corner_radius
            %}
          {% else %}
            <div class="content-card collection-empty">
              <p>Nenhum produto encontrado nesta coleção.</p>
            </div>
          {% endfor %}
        </div>
    {% endcase %}
  {% endfor %}
</section>

{% schema %}
{
  "name": "Coleção em blocos",
  "settings": [
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Título",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Todos os produtos"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Tamanho do título",
          "min": 18,
          "max": 48,
          "step": 1,
          "unit": "px",
          "default": 26
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo"
        },
        {
          "type": "range",
          "id": "subtitle_size",
          "label": "Tamanho do subtítulo",
          "min": 10,
          "max": 22,
          "step": 1,
          "unit": "px",
          "default": 13
        },
        {
          "type": "checkbox",
          "id": "show_product_count",
          "label": "Mostrar quantidade de produtos",
          "default": false
        }
      ]
    },
    {
      "type": "product_grid",
      "name": "Produtos",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "columns_desktop",
          "label": "Colunas no desktop",
          "options": [
            {
              "value": "2",
              "label": "2"
            },
            {
              "value": "3",
              "label": "3"
            },
            {
              "value": "4",
              "label": "4"
            }
          ],
          "default": "4"
        },
        {
          "type": "checkbox",
          "id": "show_media",
          "label": "Exibe a mídia do produto principal",
          "default": true
        },
        {
          "type": "select",
          "id": "media_ratio",
          "label": "Proporção",
          "options": [
            {
              "value": "adapt",
              "label": "Automático"
            },
            {
              "value": "portrait",
              "label": "Retrato"
            },
            {
              "value": "square",
              "label": "Quadrado"
            },
            {
              "value": "landscape",
              "label": "Paisagem"
            }
          ],
          "default": "adapt"
        },
        {
          "type": "header",
          "content": "Bordas"
        },
        {
          "type": "select",
          "id": "border_style",
          "label": "Estilo",
          "options": [
            {
              "value": "none",
              "label": "Nenhum"
            },
            {
              "value": "solid",
              "label": "Sólido"
            }
          ],
          "default": "none"
        },
        {
          "type": "range",
          "id": "corner_radius",
          "label": "Raio do canto",
          "min": 0,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coleção em blocos",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "product_grid"
        }
      ]
    }
  ]
}
{% endschema %}
