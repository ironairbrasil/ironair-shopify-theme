{{ 'featured-products.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{% assign selected_collection = section.settings.collection | default: collections.all %}

<section class="section-anchor shopify-featured-product" id="produtos">
  <div class="section-head">
    <div>
      <div class="section-kicker">{{ section.settings.kicker }}</div>
      <h2>{{ section.settings.title }}</h2>
    </div>

    <a href="{{ routes.all_products_collection_url }}">
      {{ section.settings.link_label }}
    </a>
  </div>

  <div class="products-grid cols3 is-stack-mobile">
    {% for product in selected_collection.products limit: 12 %}
      {% render 'product-card', product: product %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Produto conectado",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Selo",
      "default": "Oferta especial"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Nossos produtos"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link",
      "default": "Ver todos →"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção de produtos"
    }
  ],
  "presets": [
    {
      "name": "Produto conectado"
    }
  ]
}
{% endschema %}
