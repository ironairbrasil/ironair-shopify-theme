<section class="page page-stack shopify-padding-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  <div class="content-card page-content">
    <h1>Página não encontrada</h1>
    <p>Volte para a loja e continue navegando.</p>
    <a class="btn-hero" href="{{ routes.root_url }}">Ir para o início</a>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": [
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ]
}
{% endschema %}
