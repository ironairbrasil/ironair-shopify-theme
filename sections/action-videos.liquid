{{ 'action-videos.css' | asset_url | stylesheet_tag }}
<script src="{{ 'action-videos.js' | asset_url }}" defer></script>

<section class="action-videos shopify-padding-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;" data-action-videos>
  {% assign title_blocks = section.blocks | where: 'type', 'title' %}
  {% assign title_block = title_blocks.first %}
  {% assign video_blocks = section.blocks | where: 'type', 'video' %}
  <div class="action-videos-inner">
    <div class="action-videos-head">
      {% if title_block != blank or section.settings.title != blank %}
        <h2 class="action-videos-title" style="font-size: {{ title_block.settings.title_size | default: 30 }}px;" {% if title_block != blank %}{{ title_block.shopify_attributes }}{% endif %}>{{ title_block.settings.title | default: section.settings.title | escape }}</h2>
      {% endif %}
      {% if title_block.settings.subtitle != blank or section.settings.subtitle != blank %}
        <p class="action-videos-subtitle" style="font-size: {{ title_block.settings.subtitle_size | default: 15 }}px;">{{ title_block.settings.subtitle | default: section.settings.subtitle | escape }}</p>
      {% endif %}
    </div>

    <div class="action-videos-shell">
      {% if video_blocks.size > 1 %}
        <button type="button" class="action-videos-arrow is-prev" data-action-videos-prev aria-label="Vídeo anterior">‹</button>
        <button type="button" class="action-videos-arrow is-next" data-action-videos-next aria-label="Próximo vídeo">›</button>
      {% endif %}

      <div class="action-videos-track" data-action-videos-track>
        {% for block in video_blocks %}
          {% assign product = block.settings.product | default: section.settings.product %}
          <article class="action-video-card" data-action-video-card {{ block.shopify_attributes }}>
            <div class="action-video-media">
              {% if block.settings.video != blank %}
                {{ block.settings.video | video_tag: autoplay: false, loop: true, muted: true, controls: false, playsinline: true, preload: 'metadata', image_size: '900x', class: 'action-video-player' }}
              {% elsif block.settings.poster != blank %}
                {{ block.settings.poster | image_url: width: 900 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'action-video-poster' }}
              {% else %}
                <div class="action-video-placeholder">
                  <span>{{ block.settings.title | default: 'Adicione um vídeo vertical' | escape }}</span>
                </div>
              {% endif %}

              <button type="button" class="action-video-sound" data-action-video-sound aria-label="Ativar som" aria-pressed="false">
                <svg class="sound-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11 5 6 9H3v6h3l5 4V5Z"></path>
                  <path d="m22 9-6 6"></path>
                  <path d="m16 9 6 6"></path>
                </svg>
                <svg class="sound-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11 5 6 9H3v6h3l5 4V5Z"></path>
                  <path d="M15.5 8.5a5 5 0 0 1 0 7"></path>
                  <path d="M18.5 5.5a9 9 0 0 1 0 13"></path>
                </svg>
              </button>
            </div>

            {% if product != blank %}
              {% assign product_thumb = product.featured_media.preview_image | default: product.featured_image %}
              <a class="action-video-product" href="{{ product.url }}">
                {% if product_thumb %}
                  {{ product_thumb | image_url: width: 160, height: 160, crop: 'center' | image_tag: loading: 'lazy', alt: product.title }}
                {% endif %}
                <span>
                  <strong>{{ product.title }}</strong>
                  <span>{{ block.settings.product_label | default: 'Ver produto' }}</span>
                </span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 18l6-6-6-6"></path>
                </svg>
              </a>
            {% elsif block.settings.title != blank or block.settings.caption != blank %}
              {% assign video_thumb = block.settings.poster | default: block.settings.video.preview_image %}
              <div class="action-video-product">
                {% if video_thumb != blank %}
                  {{ video_thumb | image_url: width: 160, height: 160, crop: 'center' | image_tag: loading: 'lazy', alt: block.settings.title }}
                {% endif %}
                <span>
                  {% if block.settings.title != blank %}
                    <strong>{{ block.settings.title | escape }}</strong>
                  {% endif %}
                  {% if block.settings.caption != blank %}
                    <span>{{ block.settings.caption | escape }}</span>
                  {% endif %}
                </span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 18l6-6-6-6"></path>
                </svg>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vídeos em ação",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Produto padrão"
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Título",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Veja o Iron Air em ação"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Tamanho do título",
          "min": 18,
          "max": 56,
          "step": 1,
          "unit": "px",
          "default": 30
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo",
          "default": "Vídeos rápidos mostrando o produto no dia a dia."
        },
        {
          "type": "range",
          "id": "subtitle_size",
          "label": "Tamanho do subtítulo",
          "min": 10,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 15
        }
      ]
    },
    {
      "type": "video",
      "name": "Vídeo",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Vídeo vertical"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Capa"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Iron Air em uso"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Legenda",
          "default": "Veja o resultado"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Produto"
        },
        {
          "type": "text",
          "id": "product_label",
          "label": "Texto do link do produto",
          "default": "Ver produto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vídeos em ação",
      "blocks": [
        {
          "type": "video"
        },
        {
          "type": "video"
        },
        {
          "type": "video"
        },
        {
          "type": "video"
        },
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}
