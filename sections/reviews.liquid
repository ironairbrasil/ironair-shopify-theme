{{ 'reviews.css' | asset_url | stylesheet_tag }}
{{ 'reviews.js' | asset_url | script_tag }}

<section class="reviews-section section-anchor shopify-padding-section" id="depoimentos" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% assign title_blocks = section.blocks | where: 'type', 'title' %}
  {% assign title_block = title_blocks.first %}
  <div class="section-head section-head--align-{{ title_block.settings.title_alignment | default: 'left' }}">
    {% if title_block != blank or section.settings.title != blank %}
      <div>
        <h2 class="responsive-font-size" style="--font-size-desktop: {{ title_block.settings.title_size | default: 30 }}px; --font-size-mobile: {{ title_block.settings.title_size_mobile | default: title_block.settings.title_size | default: 30 }}px;" {% if title_block != blank %}{{ title_block.shopify_attributes }}{% endif %}>{{ title_block.settings.title | default: section.settings.title }}</h2>
      </div>
    {% endif %}
    <div class="section-rating">
      <span>★★★★★</span>
      <strong>{{ section.settings.rating }}</strong>
      <small>{{ section.settings.count }}</small>
    </div>
  </div>
  <div class="reviews-grid">
    {% for block in section.blocks %}
      {% if block.type == 'title' %}{% continue %}{% endif %}
      <article class="review-card{% if block.settings.image != blank %} has-review-media{% endif %}" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <div class="rv-media">
            {{ block.settings.image | image_url: width: 720 | image_tag: alt: block.settings.name, class: 'rv-media-image', loading: 'lazy' }}
          </div>
        {% endif %}
        <div class="rv-stars">{{ block.settings.stars }}</div>
        <div class="rv-author">
          <div class="rv-name">
            <span>{{ block.settings.name }}</span>
            <span class="rv-verified-badge" aria-label="Verificado">✓</span>
          </div>
        </div>
        <p class="rv-text">{{ block.settings.text }}</p>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Depoimentos",
  "settings": [
    {
      "type": "text",
      "id": "rating",
      "label": "Nota",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "count",
      "label": "Quantidade",
      "default": "847 avaliações"
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Título",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "O que dizem os clientes"
        },
        {
          "type": "select",
          "id": "title_alignment",
          "label": "Alinhamento",
          "default": "left",
          "options": [
            {
              "value": "left",
              "label": "Esquerda"
            },
            {
              "value": "center",
              "label": "Centro"
            },
            {
              "value": "right",
              "label": "Direita"
            }
          ]
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Tamanho do título no desktop",
          "min": 18,
          "max": 56,
          "step": 1,
          "unit": "px",
          "default": 30
        },
        {
          "type": "range",
          "id": "title_size_mobile",
          "label": "Tamanho do título no mobile",
          "min": 18,
          "max": 56,
          "step": 1,
          "unit": "px",
          "default": 30
        }
      ]
    },
    {
      "type": "review",
      "name": "Depoimento",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto de demonstração"
        },
        {
          "type": "text",
          "id": "stars",
          "label": "Estrelas",
          "default": "★★★★★"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "Tirei minha camisa da secadora toda amarrotada e em 12 minutos já estava passada, parecia nova."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nome",
          "default": "Marina Silva"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Depoimentos",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "review",
          "settings": {
            "name": "Marina Silva",
            "text": "Tirei minha camisa da secadora toda amarrotada e em 12 minutos já estava passada, parecia nova. Nunca mais precisei de tábua de passar."
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Roberto Santos",
            "text": "Trabalho com eventos e preciso estar impecável todo dia. O Iron Air me salva nas manhãs enquanto eu tomo café."
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Juliana Costa",
            "text": "Dei de presente para minha mãe que tem dores nas costas. Ela ficou emocionada e a rotina mudou de verdade."
          }
        }
      ]
    }
  ]
}
{% endschema %}
