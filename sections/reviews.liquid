{{ 'reviews.css' | asset_url | stylesheet_tag }}
{{ 'reviews.js' | asset_url | script_tag }}

<section class="reviews-section section-anchor" id="depoimentos">
  <div class="section-head">
    <div>
      <div class="section-kicker">{{ section.settings.subtitle }}</div>
      <h2>{{ section.settings.title }}</h2>
    </div>
    <div class="section-rating">
      <span>★★★★★</span>
      <strong>{{ section.settings.rating }}</strong>
      <small>{{ section.settings.count }}</small>
    </div>
  </div>
  <div class="reviews-grid">
    {% for block in section.blocks %}
      {% assign fallback_asset = 'depoimento-1.jpg' %}
      {% if forloop.index == 2 %}{% assign fallback_asset = 'depoimento-2.jpg' %}{% endif %}
      {% if forloop.index == 3 %}{% assign fallback_asset = 'depoimento-3.jpg' %}{% endif %}
      <article class="review-card" {{ block.shopify_attributes }}>
        <div class="rv-stars">{{ block.settings.stars }}</div>
        <p class="rv-text">"{{ block.settings.text }}"</p>
        <div class="rv-author">
          <div class="rv-av rv-{{ block.settings.tone }}">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 96 | image_tag: alt: block.settings.name, class: 'rv-av-image', loading: 'lazy' }}
            {% else %}
              <img class="rv-av-image" src="{{ fallback_asset | asset_url }}" alt="{{ block.settings.name | escape }}">
            {% endif %}
          </div>
          <div>
            <div class="rv-name">{{ block.settings.name }}</div>
            <div class="rv-city">{{ block.settings.city }}</div>
            <div class="rv-check">✓ Compra verificada</div>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Depoimentos",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtítulo", "default": "Clientes reais" },
    { "type": "text", "id": "title", "label": "Título", "default": "O que dizem os clientes" },
    { "type": "text", "id": "rating", "label": "Nota", "default": "4.8" },
    { "type": "text", "id": "count", "label": "Quantidade", "default": "847 avaliações" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Depoimento",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Foto" },
        { "type": "text", "id": "stars", "label": "Estrelas", "default": "★★★★★" },
        { "type": "textarea", "id": "text", "label": "Texto", "default": "Tirei minha camisa da secadora toda amarrotada e em 12 minutos já estava passada, parecia nova." },
        { "type": "text", "id": "name", "label": "Nome", "default": "Marina Silva" },
        { "type": "text", "id": "city", "label": "Cidade", "default": "São Paulo, SP" },
        { "type": "select", "id": "tone", "label": "Cor", "default": "red", "options": [
          { "value": "red", "label": "Vermelho" },
          { "value": "blue", "label": "Azul" },
          { "value": "green", "label": "Verde" }
        ] }
      ]
    }
  ],
  "presets": [
    {
      "name": "Depoimentos",
      "blocks": [
        { "type": "review", "settings": { "name": "Marina Silva", "city": "São Paulo, SP", "tone": "red", "text": "Tirei minha camisa da secadora toda amarrotada e em 12 minutos já estava passada, parecia nova. Nunca mais precisei de tábua de passar." } },
        { "type": "review", "settings": { "name": "Roberto Santos", "city": "Curitiba, PR", "tone": "blue", "text": "Trabalho com eventos e preciso estar impecável todo dia. O Iron Air me salva nas manhãs enquanto eu tomo café." } },
        { "type": "review", "settings": { "name": "Juliana Costa", "city": "Brasília, DF", "tone": "green", "text": "Dei de presente para minha mãe que tem dores nas costas. Ela ficou emocionada e a rotina mudou de verdade." } }
      ]
    }
  ]
}
{% endschema %}
