{{ 'featured-products.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{% assign related_collection = product.collections.first %}
{% if related_collection != blank %}
  <section class="page page-stack related-products-section shopify-padding-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
    <div class="section-head">
      <div>
        <h2>{{ section.settings.title }}</h2>
      </div>
    </div>
    <div class="products-grid cols3 is-stack-mobile">
      {% for related_product in related_collection.products limit: section.settings.limit %}
        {% unless related_product.id == product.id %}
          {% render 'product-card', product: related_product %}
        {% endunless %}
      {% endfor %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Produtos relacionados",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Produtos relacionados"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Limite",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ]
}
{% endschema %}
