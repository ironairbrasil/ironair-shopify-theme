{{ 'collection-page.css' | asset_url | stylesheet_tag }}
{{ 'featured-products.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}
{{ 'featured-products.js' | asset_url | script_tag }}

{% assign selected_collection = section.settings.collection | default: collection | default: collections.all %}
{% assign products_by_creation = selected_collection.products | sort: 'created_at' %}

<section class="section-anchor page page-stack shopify-padding-section theme-text-align-{{ section.settings.text_alignment | default: 'left' }} theme-mobile-text-align-{{ section.settings.mobile_text_alignment | default: section.settings.text_alignment | default: 'left' }} theme-content-align-{{ section.settings.content_alignment | default: section.settings.text_alignment | default: 'left' }} theme-mobile-content-align-{{ section.settings.mobile_content_alignment | default: section.settings.content_alignment | default: section.settings.mobile_text_alignment | default: section.settings.text_alignment | default: 'left' }}{% if section.settings.hide_on_mobile %} theme-hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} theme-hide-desktop{% endif %}" id="produtos" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'title' %}
        <div class="sec-header theme-block-align-{{ block.settings.block_text_alignment | default: 'inherit' }} theme-block-mobile-align-{{ block.settings.block_mobile_text_alignment | default: block.settings.block_text_alignment | default: 'inherit' }}" {{ block.shopify_attributes }}>
          <div class="sec-header-copy">
            <div class="sec-title responsive-font-size" style="--font-size-desktop: {{ block.settings.title_size | default: 26 }}px; --font-size-mobile: {{ block.settings.title_size_mobile | default: block.settings.title_size | default: 26 }}px;">{{ block.settings.title | escape }}</div>
            {% if block.settings.show_product_count %}
              <span class="sec-subtitle responsive-font-size theme-block-align-{{ block.settings.block_text_alignment | default: 'inherit' }} theme-block-mobile-align-{{ block.settings.block_mobile_text_alignment | default: block.settings.block_text_alignment | default: 'inherit' }}" style="--font-size-desktop: {{ block.settings.subtitle_size | default: 13 }}px; --font-size-mobile: {{ block.settings.subtitle_size_mobile | default: block.settings.subtitle_size | default: 13 }}px;">{{ selected_collection.products_count }} produto{% unless selected_collection.products_count == 1 %}s{% endunless %}</span>
            {% elsif block.settings.subtitle != blank %}
              <span class="sec-subtitle responsive-font-size theme-block-align-{{ block.settings.block_text_alignment | default: 'inherit' }} theme-block-mobile-align-{{ block.settings.block_mobile_text_alignment | default: block.settings.block_text_alignment | default: 'inherit' }}" style="--font-size-desktop: {{ block.settings.subtitle_size | default: 13 }}px; --font-size-mobile: {{ block.settings.subtitle_size_mobile | default: block.settings.subtitle_size | default: 13 }}px;">{{ block.settings.subtitle | escape }}</span>
            {% endif %}
          </div>
        </div>

      {% when 'products' %}
        {% assign display_mode = block.settings.display_mode | default: 'grid' %}
        {% assign columns_desktop = block.settings.columns_desktop | default: '4' %}
        {% assign columns_mobile = '1' %}
        {% if block.settings.display_mode == 'carousel' %}
          {% assign columns_desktop = block.settings.carousel_columns_desktop | default: columns_desktop %}
          {% assign columns_mobile = block.settings.carousel_columns_mobile | default: '1' %}
        {% endif %}
        {% assign products_limit = block.settings.products_limit | default: 50 %}
        {% assign use_carousel = false %}
        {% if display_mode == 'carousel' %}
          {% assign use_carousel = true %}
        {% endif %}

        {% if use_carousel %}
          <div class="products-carousel-shell theme-block-align-{{ block.settings.block_text_alignment | default: 'inherit' }} theme-block-mobile-align-{{ block.settings.block_mobile_text_alignment | default: block.settings.block_text_alignment | default: 'inherit' }}" data-products-carousel {{ block.shopify_attributes }}>
            <div class="products-carousel-head">
              {% if block.settings.carousel_link_label != blank %}
                <a class="products-carousel-link" href="{{ block.settings.carousel_link_url | default: routes.all_products_collection_url }}">{{ block.settings.carousel_link_label }}</a>
              {% endif %}
              <div class="products-carousel-nav" aria-label="Navegar produtos">
                <button type="button" class="products-carousel-arrow" data-products-prev aria-label="Produtos anteriores">‹</button>
                <button type="button" class="products-carousel-arrow" data-products-next aria-label="Próximos produtos">›</button>
              </div>
            </div>
        {% endif %}

        <div class="products-grid cols{{ columns_desktop }} mobile-cols{{ columns_mobile }} {% if use_carousel %}is-carousel{% else %}is-stack-mobile{% endif %} theme-block-align-{{ block.settings.block_text_alignment | default: 'inherit' }} theme-block-mobile-align-{{ block.settings.block_mobile_text_alignment | default: block.settings.block_text_alignment | default: 'inherit' }}" {% unless use_carousel %}{{ block.shopify_attributes }}{% endunless %} {% if use_carousel %}data-products-track{% endif %}>
          {% for product in products_by_creation limit: products_limit %}
            {% render 'product-card',
              product: product,
              show_media: block.settings.show_media,
              media_ratio: block.settings.media_ratio,
              border_style: block.settings.border_style,
              corner_radius: block.settings.corner_radius
            %}
          {% else %}
            <div class="content-card collection-empty">
              <p>Nenhum produto encontrado nesta coleção.</p>
            </div>
          {% endfor %}
        </div>

        {% if use_carousel %}
          </div>
        {% endif %}
    {% endcase %}
  {% endfor %}
</section>

