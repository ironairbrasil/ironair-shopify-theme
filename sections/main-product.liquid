{{ 'product-page.css' | asset_url | stylesheet_tag }}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign pix_discount_percent = 10 %}
{% assign installments_count = 12 %}

{% for block in section.blocks %}
  {% if block.type == 'price' %}
    {% assign pix_discount_percent = block.settings.pix_discount_percent %}
    {% assign installments_count = block.settings.installments_count %}
  {% endif %}
{% endfor %}

{% assign pix_multiplier = 100 | minus: pix_discount_percent %}
{% assign price = current_variant.price %}
{% assign compare_price = current_variant.compare_at_price %}
{% assign pix_price = price | times: pix_multiplier | divided_by: 100 %}
{% assign installments = price | divided_by: installments_count %}
{% assign discount = 0 %}
{% assign upsell_manual_limit = 0 %}
{% assign upsell_fallback_limit = 0 %}
{% if compare_price > price %}
  {% assign discount = compare_price | minus: price | times: 100 | divided_by: compare_price %}
{% endif %}

<section class="page product-page shopify-padding-section" data-product-root data-product-handle="{{ product.handle | escape }}" data-product-title="{{ product.title | escape }}" {% if product.featured_image %}data-product-image="{{ product.featured_image | image_url: width: 400 }}"{% endif %} style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top: 0; margin-bottom: 0;">
  <div class="product-detail-shell">
    <div class="product-media-column">
      <div class="product-gallery">
        <div class="product-gallery-main">
          {% if product.featured_media %}
            {{ product.featured_media | image_url: width: 1100 | image_tag: alt: product.title, data-main-product-image: true }}
          {% else %}
            <img src="{{ 'ironair-principal.png' | asset_url }}" alt="{{ product.title | escape }}" data-main-product-image>
          {% endif %}
        </div>
        <div class="product-gallery-thumbs">
          {% for image in product.images %}
            <button type="button" class="product-gallery-thumb {% if forloop.first %}is-active{% endif %}" data-gallery-image="{{ image | image_url: width: 1100 }}" aria-label="Ver imagem {{ forloop.index }}">
              {{ image | image_url: width: 160 | image_tag: alt: product.title, loading: 'lazy' }}
            </button>
          {% else %}
            {% assign fallback_images = 'ironair-principal.png,ironair-1.jpg,ironair-2.jpg,ironair-3.jpg,ironair-4.jpg,ironair-5.jpg' | split: ',' %}
            {% for fallback in fallback_images %}
              <button type="button" class="product-gallery-thumb {% if forloop.first %}is-active{% endif %}" data-gallery-image="{{ fallback | asset_url }}" aria-label="Ver imagem {{ forloop.index }}">
                <img src="{{ fallback | asset_url }}" alt="{{ product.title | escape }}">
              </button>
            {% endfor %}
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="product-purchase-panel">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'vendor' %}
            <div class="pc-brand" {{ block.shopify_attributes }}>
              {% if block.settings.text != blank %}
                {{ block.settings.text }}
              {% else %}
                {{ product.vendor | default: shop.name }}
              {% endif %}
            </div>

          {% when 'title' %}
            <h1
              class="responsive-font-size"
              style="--font-size-desktop: {{ block.settings.title_size | default: 40 }}px; --font-size-mobile: {{ block.settings.title_size_mobile | default: block.settings.title_size | default: 40 }}px;"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.title_override != blank %}
                {{ block.settings.title_override }}
              {% else %}
                {{ product.title }}
              {% endif %}
            </h1>

          {% when 'badge' %}
            <div
              class="pc-badge badge-off"
              {% if block.settings.badge_text == blank %}data-product-discount{% endif %}
              {{ block.shopify_attributes }}
              {% unless compare_price > price or block.settings.badge_text != blank %}hidden{% endunless %}
            >
              {% if block.settings.badge_text != blank %}
                {{ block.settings.badge_text }}
              {% else %}
                {{ discount }}% OFF
              {% endif %}
            </div>

          {% when 'price' %}
            <div class="product-price-block" {{ block.shopify_attributes }}>
              {% if block.settings.show_compare_price %}
                <div class="pc-price-old" data-product-compare-price {% unless compare_price > price %}hidden{% endunless %}>{{ compare_price | money }}</div>
              {% endif %}
              {% if block.settings.show_price %}
                <div class="product-main-price product-main-price--hidden" data-product-price>{{ price | money }}</div>
              {% endif %}
              {% if block.settings.show_pix_price %}
                <div class="product-card-payment-pix">
                  <strong data-product-pix-price>{{ pix_price | money }}</strong>
                  <span>{{ block.settings.pix_label | replace: '[discount]', pix_discount_percent }}</span>
                </div>
              {% endif %}
              {% if block.settings.show_installments %}
                <div class="product-card-payment-card">
                  ou <strong data-product-card-price>{{ price | money }}</strong> em até
                  <strong><span data-product-installments-count>{{ installments_count }}</span>x de <span data-product-installments>{{ installments | money }}</span></strong> s/juros
                </div>
              {% endif %}
            </div>

          {% when 'buy_buttons' %}
            <div {{ block.shopify_attributes }}>
              {% if product.featured_image %}
                {% assign product_checkout_image_url = product.featured_image | image_url: width: 400 %}
              {% endif %}
              {% form 'product', product, class: 'product-form', data-ironair-checkout: true, data-product-handle: product.handle, data-product-title: product.title, data-product-image: product_checkout_image_url %}
                {% unless product.has_only_default_variant %}
                  <select id="ProductSelect-{{ section.id }}" name="id" class="product-variant-native-select" data-product-variant-select aria-label="{{ block.settings.variant_label | default: 'Selecionar variante' }}">
                    <option value="" selected disabled>{{ block.settings.variant_label | default: 'Selecionar variante' }}</option>
                    {% for variant in product.variants %}
                      {% assign variant_price = variant.price %}
                      {% assign variant_compare_price = variant.compare_at_price %}
                      {% assign variant_checkout_image = product.featured_image %}
                      {% if variant.featured_image %}
                        {% assign variant_checkout_image = variant.featured_image %}
                      {% endif %}
                      {% assign variant_pix_price = variant_price | times: pix_multiplier | divided_by: 100 %}
                      {% assign variant_installments = variant_price | divided_by: installments_count %}
                      {% assign variant_discount = 0 %}
                      {% if variant_compare_price > variant_price %}
                        {% assign variant_discount = variant_compare_price | minus: variant_price | times: 100 | divided_by: variant_compare_price %}
                      {% endif %}
                      {% capture variant_stock_message %}
                        {% if variant.inventory_management %}
                          {{ variant.inventory_quantity }} unidade(s) em estoque
                        {% elsif variant.available %}
                          Em estoque
                        {% else %}
                          Produto esgotado no momento
                        {% endif %}
                      {% endcapture %}
                      <option
                        value="{{ variant.id }}"
                        data-variant-gid="gid://shopify/ProductVariant/{{ variant.id }}"
                        data-price-cents="{{ variant_price }}"
                        data-price="{{ variant_price | money }}"
                        data-product-title="{{ product.title | escape }}"
                        {% if variant_checkout_image %}data-product-image="{{ variant_checkout_image | image_url: width: 400 }}"{% endif %}
                        data-compare-price="{{ variant_compare_price | money }}"
                        data-has-compare-price="{% if variant_compare_price > variant_price %}true{% else %}false{% endif %}"
                        data-discount="{{ variant_discount }}% OFF"
                        data-pix-price="{{ variant_pix_price | money }}"
                        data-installments="{{ variant_installments | money }}"
                        data-available="{% if variant.available %}true{% else %}false{% endif %}"
                        data-stock-message="{{ variant_stock_message | strip | escape }}"
                        data-stock-state="{% if variant.available %}in{% else %}out{% endif %}"
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ variant.title }}{% unless variant.available %} - esgotado{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                  <script type="application/json" data-product-variants-json>{{ product.variants | json }}</script>
                  <div class="product-options" data-product-options>
                    {% for option in product.options_with_values %}
                      <fieldset class="product-option-group" data-option-position="{{ option.position }}">
                        <legend class="product-option-label">{{ option.name }}</legend>
                        <div class="product-variant-buttons">
                          {% for value in option.values %}
                            {% assign value_variant = blank %}
                            {% if product.options.size == 1 %}
                              {% for variant in product.variants %}
                                {% if variant.option1 == value %}
                                  {% assign value_variant = variant %}
                                  {% break %}
                                {% endif %}
                              {% endfor %}
                            {% endif %}
                            <button
                              type="button"
                              class="product-variant-button"
                              data-variant-option-button
                              data-option-position="{{ option.position }}"
                              data-option-value="{{ value | escape }}"
                              {% if value_variant != blank %}data-variant-id="{{ value_variant.id }}"{% endif %}
                              aria-pressed="false"
                            >
                              {{ value }}
                            </button>
                          {% endfor %}
                        </div>
                      </fieldset>
                    {% endfor %}
                  </div>
                {% else %}
                  {% assign current_checkout_image = product.featured_image %}
                  {% if current_variant.featured_image %}
                    {% assign current_checkout_image = current_variant.featured_image %}
                  {% endif %}
                  <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-gid="gid://shopify/ProductVariant/{{ current_variant.id }}" data-price-cents="{{ current_variant.price }}" data-product-title="{{ product.title | escape }}" {% if current_checkout_image %}data-product-image="{{ current_checkout_image | image_url: width: 400 }}"{% endif %}>
                {% endunless %}
                {% if block.settings.show_stock %}
                  {% if product.has_only_default_variant %}
                    {% if current_variant.inventory_management %}
                      <div class="product-stock-line {% unless current_variant.available %}is-out{% endunless %}" data-product-stock-message data-stock-prefix="{{ block.settings.stock_prefix | escape }}">{{ block.settings.stock_prefix }} {{ current_variant.inventory_quantity }} unidade(s) em estoque</div>
                    {% elsif current_variant.available %}
                      <div class="product-stock-line" data-product-stock-message data-stock-prefix="{{ block.settings.stock_prefix | escape }}">{{ block.settings.stock_prefix }} Em estoque</div>
                    {% else %}
                      <div class="product-stock-line is-out" data-product-stock-message data-stock-prefix="{{ block.settings.stock_prefix | escape }}">Produto esgotado no momento</div>
                    {% endif %}
                  {% else %}
                    <div class="product-stock-line is-out" data-product-stock-message data-stock-prefix="{{ block.settings.stock_prefix | escape }}">Selecione a voltagem para continuar</div>
                  {% endif %}
                {% endif %}
                <button class="btn-hero product-submit" type="submit" data-product-submit data-ironair-checkout {% if product.has_only_default_variant %}{% unless current_variant.available %}disabled{% endunless %}{% else %}disabled{% endif %}>
                  {{ block.settings.button_label }}
                </button>
                <button class="btn-hero product-submit product-submit-secondary" type="submit" data-product-submit data-add-to-cart {% if product.has_only_default_variant %}{% unless current_variant.available %}disabled{% endunless %}{% else %}disabled{% endif %}>
                  Adicionar ao carrinho
                </button>
              {% endform %}
            </div>

          {% when 'upsells' %}
            {% assign upsell_products = block.settings.products %}
            {% assign fallback_collection = product.collections.first %}
            {% assign upsell_display_limit = block.settings.limit | default: 4 %}
            {% if upsell_products != blank and upsell_products.size > upsell_display_limit %}
              {% assign upsell_display_limit = upsell_products.size %}
            {% endif %}
            {% if upsell_products != blank or fallback_collection != blank %}
              <div class="product-upsells" {{ block.shopify_attributes }}>
                {% if block.settings.title != blank %}
                  <h2>{{ block.settings.title }}</h2>
                {% endif %}
                <div class="product-upsell-list">
                  {% if upsell_products != blank %}
                    {% for upsell_product in upsell_products %}
                      {% unless upsell_product.id == product.id %}
                        {% if upsell_manual_limit < upsell_display_limit %}
                          {% assign upsell_manual_limit = upsell_manual_limit | plus: 1 %}
                          {% assign upsell_variant = upsell_product.selected_or_first_available_variant %}
                          <article class="product-upsell-card">
                            <a class="product-upsell-media" href="{{ upsell_product.url }}">
                              {% if upsell_product.featured_image %}
                                {{ upsell_product.featured_image | image_url: width: 180 | image_tag: alt: upsell_product.title, loading: 'lazy' }}
                              {% else %}
                                <img src="{{ 'ironair-principal.png' | asset_url }}" alt="{{ upsell_product.title | escape }}" loading="lazy">
                              {% endif %}
                            </a>
                            <div class="product-upsell-copy">
                              <a href="{{ upsell_product.url }}">{{ upsell_product.title }}</a>
                              <strong>{{ upsell_variant.price | money }}</strong>
                            </div>
                            {% if upsell_product.has_only_default_variant %}
                              <form method="post" action="{{ routes.cart_add_url }}">
                                <input type="hidden" name="id" value="{{ upsell_variant.id }}">
                                <button type="submit" {% unless upsell_variant.available %}disabled{% endunless %}>Adicionar</button>
                              </form>
                            {% else %}
                              <a class="product-upsell-action" href="{{ upsell_product.url }}">Escolher</a>
                            {% endif %}
                          </article>
                        {% endif %}
                      {% endunless %}
                    {% endfor %}
                  {% else %}
                    {% for upsell_product in fallback_collection.products %}
                      {% unless upsell_product.id == product.id %}
                        {% if upsell_fallback_limit < upsell_display_limit %}
                          {% assign upsell_fallback_limit = upsell_fallback_limit | plus: 1 %}
                          {% assign upsell_variant = upsell_product.selected_or_first_available_variant %}
                          <article class="product-upsell-card">
                            <a class="product-upsell-media" href="{{ upsell_product.url }}">
                              {% if upsell_product.featured_image %}
                                {{ upsell_product.featured_image | image_url: width: 180 | image_tag: alt: upsell_product.title, loading: 'lazy' }}
                              {% else %}
                                <img src="{{ 'ironair-principal.png' | asset_url }}" alt="{{ upsell_product.title | escape }}" loading="lazy">
                              {% endif %}
                            </a>
                            <div class="product-upsell-copy">
                              <a href="{{ upsell_product.url }}">{{ upsell_product.title }}</a>
                              <strong>{{ upsell_variant.price | money }}</strong>
                            </div>
                            {% if upsell_product.has_only_default_variant %}
                              <form method="post" action="{{ routes.cart_add_url }}">
                                <input type="hidden" name="id" value="{{ upsell_variant.id }}">
                                <button type="submit" {% unless upsell_variant.available %}disabled{% endunless %}>Adicionar</button>
                              </form>
                            {% else %}
                              <a class="product-upsell-action" href="{{ upsell_product.url }}">Escolher</a>
                            {% endif %}
                          </article>
                        {% endif %}
                      {% endunless %}
                    {% endfor %}
                  {% endif %}
                </div>
              </div>
            {% endif %}

          {% when 'description' %}

          {% when 'benefits' %}
            <div class="final-points product-points" {{ block.shopify_attributes }}>
              {% if block.settings.benefit_1 != blank %}<div>{{ block.settings.benefit_1 }}</div>{% endif %}
              {% if block.settings.benefit_2 != blank %}<div>{{ block.settings.benefit_2 }}</div>{% endif %}
              {% if block.settings.show_stock %}
                {% if current_variant.inventory_management and current_variant.inventory_quantity > 0 %}
                  <div data-product-stock-message>{{ block.settings.stock_prefix }} {{ current_variant.inventory_quantity }} unidade(s) em estoque</div>
                {% elsif current_variant.available %}
                  <div data-product-stock-message>{{ block.settings.stock_prefix }} Em estoque</div>
                {% else %}
                  <div data-product-stock-message>Produto esgotado no momento</div>
                {% endif %}
              {% endif %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>

  {% for block in section.blocks %}
    {% if block.type == 'description' %}
      {% capture product_description_html %}
        {% if block.settings.description_override != blank %}
          {{ block.settings.description_override }}
        {% elsif product.metafields.custom.description != blank %}
          {{ product.metafields.custom.description | metafield_tag }}
        {% else %}
          {{ product.description }}
        {% endif %}
      {% endcapture %}

      {% assign product_description_html_stripped = product_description_html | strip %}
      {% if product_description_html_stripped != blank %}
        <div class="product-description-section">
          <div
            class="product-description-card product-description-card--{{ block.settings.width }} product-description-card--align-{{ block.settings.alignment }} {% if block.settings.show_background %}has-background{% endif %} {% if block.settings.show_border %}has-border{% endif %}"
            style="--description-padding-top: {{ block.settings.padding_top }}px; --description-padding-bottom: {{ block.settings.padding_bottom }}px; --description-padding-left: {{ block.settings.padding_left }}px; --description-padding-right: {{ block.settings.padding_right }}px; --description-border-radius: {{ block.settings.border_radius }}px;"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.heading != blank %}
              <h2>{{ block.settings.heading | escape }}</h2>
            {% endif %}
            <div class="product-detail-copy">
              {{ product_description_html }}
            </div>
          </div>
        </div>
      {% endif %}
    {% elsif block.type == 'specifications' %}
      {% capture product_specifications_html %}
        {% if block.settings.specifications_override != blank %}
          {{ block.settings.specifications_override }}
        {% elsif product.metafields.custom.specifications != blank %}
          {{ product.metafields.custom.specifications | metafield_tag }}
        {% endif %}
      {% endcapture %}

      {% assign product_specifications_html_stripped = product_specifications_html | strip %}
      {% if product_specifications_html_stripped != blank %}
        <div class="product-description-section">
          <div
            class="product-description-card product-description-card--{{ block.settings.width }} product-description-card--align-{{ block.settings.alignment }} {% if block.settings.show_background %}has-background{% endif %} {% if block.settings.show_border %}has-border{% endif %}"
            style="--description-padding-top: {{ block.settings.padding_top }}px; --description-padding-bottom: {{ block.settings.padding_bottom }}px; --description-padding-left: {{ block.settings.padding_left }}px; --description-padding-right: {{ block.settings.padding_right }}px; --description-border-radius: {{ block.settings.border_radius }}px;"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.heading != blank %}
              <h2>{{ block.settings.heading | escape }}</h2>
            {% endif %}
            <div class="product-detail-copy">
              {{ product_specifications_html }}
            </div>
          </div>
        </div>
      {% endif %}
    {% endif %}
  {% endfor %}
</section>

{% schema %}
{
  "name": "Produto principal",
  "settings": [
    {
      "type": "header",
      "content": "Preenchimento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "vendor",
      "name": "Marca",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto personalizado",
          "info": "Deixe vazio para usar o fabricante do produto."
        }
      ]
    },
    {
      "type": "title",
      "name": "Nome",
      "settings": [
        {
          "type": "text",
          "id": "title_override",
          "label": "Nome personalizado",
          "info": "Deixe vazio para usar o nome do produto."
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Tamanho no desktop",
          "min": 20,
          "max": 72,
          "step": 1,
          "unit": "px",
          "default": 40
        },
        {
          "type": "range",
          "id": "title_size_mobile",
          "label": "Tamanho no mobile",
          "min": 20,
          "max": 56,
          "step": 1,
          "unit": "px",
          "default": 40
        }
      ]
    },
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "badge_text",
          "label": "Texto personalizado",
          "info": "Deixe vazio para calcular o % OFF automaticamente."
        }
      ]
    },
    {
      "type": "price",
      "name": "Preço",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_compare_price",
          "label": "Mostrar preço riscado",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_price",
          "label": "Mostrar preço atual",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_pix_price",
          "label": "Mostrar Pix",
          "default": true
        },
        {
          "type": "range",
          "id": "pix_discount_percent",
          "label": "Desconto visual no Pix",
          "min": 0,
          "max": 30,
          "step": 1,
          "unit": "%",
          "default": 10
        },
        {
          "type": "text",
          "id": "pix_label",
          "label": "Texto do Pix",
          "default": "com [discount]% OFF no Pix"
        },
        {
          "type": "checkbox",
          "id": "show_installments",
          "label": "Mostrar parcelamento",
          "default": true
        },
        {
          "type": "range",
          "id": "installments_count",
          "label": "Parcelas",
          "min": 1,
          "max": 12,
          "step": 1,
          "default": 12
        }
      ]
    },
    {
      "type": "buy_buttons",
      "name": "Botão",
      "settings": [
        {
          "type": "text",
          "id": "variant_label",
          "label": "Texto do seletor de variante",
          "default": "Selecionar variante"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Texto do botão",
          "default": "Comprar agora"
        },
        {
          "type": "checkbox",
          "id": "show_stock",
          "label": "Mostrar estoque perto do botão",
          "default": true
        },
        {
          "type": "text",
          "id": "stock_prefix",
          "label": "Prefixo do estoque",
          "default": "✓"
        }
      ]
    },
    {
      "type": "upsells",
      "name": "Adicione também",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Adicione também ao carrinho"
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "Produtos",
          "limit": 6,
          "info": "Se ficar vazio, usa produtos da primeira coleção deste produto."
        },
        {
          "type": "range",
          "id": "limit",
          "label": "Limite",
          "min": 1,
          "max": 6,
          "step": 1,
          "default": 4
        }
      ]
    },
    {
      "type": "description",
      "name": "Descrição",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Descrição"
        },
        {
          "type": "richtext",
          "id": "description_override",
          "label": "Texto",
          "info": "Deixe vazio para usar a descrição do produto."
        },
        {
          "type": "paragraph",
          "content": "Se existir, o metafield custom.description substitui a descrição padrão do produto."
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Largura",
          "default": "fill",
          "options": [
            { "value": "fit", "label": "Ajustar" },
            { "value": "fill", "label": "Preencher" }
          ]
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alinhamento",
          "default": "left",
          "options": [
            { "value": "left", "label": "Esquerda" },
            { "value": "center", "label": "Centro" },
