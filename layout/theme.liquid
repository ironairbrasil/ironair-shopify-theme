<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary | default: '#103d3e' }}">
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; Página {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="icon" href="{{ 'favicon.png' | asset_url }}">
    {{ content_for_header }}
    {{ 'variables.css' | asset_url | stylesheet_tag }}
    {% liquid
      assign title_font = settings.type_header_font
      assign body_font = settings.type_body_font
      assign title_font_semibold = title_font | font_modify: 'weight', '600'
      assign body_font_semibold = body_font | font_modify: 'weight', '600'
      assign body_font_bold = body_font | font_modify: 'weight', '700'
    %}
    <style>
      {{ title_font | font_face: font_display: 'swap' }}
      {{ title_font_semibold | font_face: font_display: 'swap' }}
      {{ body_font | font_face: font_display: 'swap' }}
      {{ body_font_semibold | font_face: font_display: 'swap' }}
      {{ body_font_bold | font_face: font_display: 'swap' }}

      :root {
        --font-title: {{ title_font.family }}, {{ title_font.fallback_families }};
        --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
        --font-size-body: {{ settings.font_size_body | default: 14 }}px;
        --font-size-paragraph: {{ settings.font_size_paragraph | default: 15 }}px;
        --font-size-small: {{ settings.font_size_small | default: 13 }}px;
        --font-size-button: {{ settings.font_size_button | default: 13 }}px;
        --font-size-heading: {{ settings.font_size_heading | default: 30 }}px;
        --font-size-heading-small: {{ settings.font_size_heading_small | default: 20 }}px;
        --font-size-hero: {{ settings.font_size_hero | default: 52 }}px;
        --font-size-product-title: {{ settings.font_size_product_title | default: 40 }}px;
        --font-size-price: {{ settings.font_size_price | default: 32 }}px;
      }

      @media (max-width: 749px) {
        :root {
          --font-size-body: {{ settings.font_size_body_mobile | default: settings.font_size_body | default: 14 }}px;
          --font-size-paragraph: {{ settings.font_size_paragraph_mobile | default: settings.font_size_paragraph | default: 15 }}px;
          --font-size-small: {{ settings.font_size_small_mobile | default: settings.font_size_small | default: 13 }}px;
          --font-size-button: {{ settings.font_size_button_mobile | default: settings.font_size_button | default: 13 }}px;
          --font-size-heading: {{ settings.font_size_heading_mobile | default: settings.font_size_heading | default: 30 }}px;
          --font-size-heading-small: {{ settings.font_size_heading_small_mobile | default: settings.font_size_heading_small | default: 20 }}px;
          --font-size-hero: {{ settings.font_size_hero_mobile | default: settings.font_size_hero | default: 52 }}px;
          --font-size-product-title: {{ settings.font_size_product_title_mobile | default: settings.font_size_product_title | default: 40 }}px;
          --font-size-price: {{ settings.font_size_price_mobile | default: settings.font_size_price | default: 32 }}px;
        }
      }
    </style>
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'utilities.css' | asset_url | stylesheet_tag }}
    {{ 'animations.css' | asset_url | stylesheet_tag }}
    {{ 'cart-drawer.css' | asset_url | stylesheet_tag }}
  </head>

  <body class="site-body">
    <div class="site-shell">
      {% sections 'header-group' %}
      <main id="MainContent" class="site-main" role="main">
        {{ content_for_layout }}
      </main>
      {% section 'footer' %}
    </div>
    {% section 'stock-reserve-popup' %}
    {% render 'cart-drawer' %}
    <script>
      window.IronAirCheckoutPrefill = {};
      {% if customer %}
        {% assign checkout_customer_phone = customer.phone | default: customer.default_address.phone %}
        {% assign checkout_customer_cpf = customer.metafields.custom.cpf.value | default: customer.metafields.custom.cpf %}
        window.IronAirCheckoutPrefill = {
          {% if customer.email != blank %}"customer[email]": {{ customer.email | json }},{% endif %}
          {% if customer.name != blank %}"customer[name]": {{ customer.name | json }},{% endif %}
          {% if checkout_customer_phone != blank %}"customer[phone]": {{ checkout_customer_phone | json }},{% endif %}
          {% if checkout_customer_cpf != blank %}"customer[cpf]": {{ checkout_customer_cpf | json }},{% endif %}
          {% if customer.default_address.zip != blank %}"defaultAddress[zip]": {{ customer.default_address.zip | json }},{% endif %}
          {% if customer.default_address.address1 != blank %}"defaultAddress[address1]": {{ customer.default_address.address1 | json }},{% endif %}
          {% if customer.default_address.address2 != blank %}"defaultAddress[address2]": {{ customer.default_address.address2 | json }},{% endif %}
          {% if customer.default_address.city != blank %}"defaultAddress[city]": {{ customer.default_address.city | json }},{% endif %}
          {% if customer.default_address.province_code != blank %}"defaultAddress[province_code]": {{ customer.default_address.province_code | json }}{% endif %}
        };
      {% endif %}
    </script>
    {{ 'app.js' | asset_url | script_tag }}
    {{ 'theme.js' | asset_url | script_tag }}
    <script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>
  </body>
</html>
