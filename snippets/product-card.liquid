{% assign variant = product.selected_or_first_available_variant %}
{% assign price = variant.price %}
{% assign checkout_price = variant.price | money_without_currency | remove: '.' | replace: ',', '.' %}
{% assign compare_price = variant.compare_at_price %}
{% assign pix_price = price | times: 90 | divided_by: 100 %}
{% assign installments = price | divided_by: 12 %}
{% assign media_ratio = media_ratio | default: 'square' %}
{% assign border_style = border_style | default: 'solid' %}
{% assign corner_radius = corner_radius | default: 8 %}
{% if compare_price > price %}
  {% assign discount = compare_price | minus: price | times: 100 | divided_by: compare_price %}
{% endif %}

<article
  class="product-card media-ratio-{{ media_ratio }} border-style-{{ border_style }}"
  id="{{ product.handle }}"
  style="--product-card-radius: {{ corner_radius }}px; {% if product.featured_image %}--product-card-media-ratio: {{ product.featured_image.aspect_ratio }};{% endif %}">
  <div class="pc-badge-wrap">
    {% unless variant.available %}
      {% render 'badge', label: 'Esgotado', class: 'badge-out' %}
    {% endunless %}
    {% if compare_price > price %}
      {% capture discount_label %}{{ discount }}% OFF{% endcapture %}
      {% render 'badge', label: discount_label, class: 'badge-off' %}
    {% endif %}
  </div>
  {% unless show_media == false %}
    <div class="pc-img">
      <a href="{{ product.url }}" class="product-figure-media">
        {% if product.featured_image %}
          {{ product.featured_image | image_url: width: 700 | image_tag: alt: product.title, class: 'pc-img-photo', loading: 'lazy' }}
        {% else %}
          <img src="{{ 'ironair-principal.png' | asset_url }}" alt="{{ product.title | escape }}" loading="lazy">
        {% endif %}
      </a>
    </div>
  {% endunless %}
  <div class="pc-body">
    <div class="pc-brand">{{ product.vendor | default: shop.name }}</div>
    <a href="{{ product.url }}" class="pc-name">{{ product.title }}</a>
    {% render 'product-price', product: product, variant: variant %}
    <div class="product-card-payment-lines">
      <div class="product-card-payment-pix">
        <strong>{{ pix_price | money }}</strong>
        <span>com 10% OFF no Pix</span>
      </div>
      <div class="product-card-payment-card">
        ou {{ price | money }} em até <strong>12x de {{ installments | money }}</strong> s/juros
      </div>
    </div>

    {% if variant.inventory_management and variant.inventory_quantity > 0 %}
      <div class="pc-stock">{{ variant.inventory_quantity }} unidade(s) em estoque</div>
    {% elsif variant.available %}
      <div class="pc-stock">Em estoque</div>
    {% else %}
      <div class="pc-stock is-out">Esgotado no momento</div>
    {% endif %}

    {% if product.has_only_default_variant %}
      {% assign card_checkout_image = product.featured_image %}
      {% if variant.featured_image %}
        {% assign card_checkout_image = variant.featured_image %}
      {% endif %}
      <a
        class="pc-btn"
        href="https://ironair-payments.vercel.app/checkout-ironair?variantId={{ 'gid://shopify/ProductVariant/' | append: variant.id | url_encode }}&quantity=1&title={{ product.title | url_encode }}&price={{ checkout_price }}{% if card_checkout_image %}&image={{ card_checkout_image | image_url: width: 400 | url_encode }}{% endif %}&productHandle={{ product.handle | url_encode }}{% render 'ironair-checkout-prefill' %}"
        {% unless variant.available %}aria-disabled="true"{% endunless %}
      >
        Comprar agora
      </a>
    {% else %}
      <a class="pc-btn" href="{{ product.url }}">Escolher opção</a>
    {% endif %}

    <form method="post" action="{{ routes.cart_add_url }}" class="product-card-add-form">
      <input type="hidden" name="id" value="{{ variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <button class="pc-btn pc-btn-secondary" type="submit" {% unless variant.available %}disabled{% endunless %}>
        Adicionar ao carrinho
      </button>
    </form>
  </div>
</article>
